}
.padding-right {
  padding-top: 0rem !important;
  padding-bottom: 0rem !important;
  padding-left: 0rem !important;
}
.margin-bottom {
  margin-top: 0rem !important;
  margin-right: 0rem !important;
  margin-left: 0rem !important;
}
.padding-bottom {
  padding-top: 0rem !important;
  padding-right: 0rem !important;
  padding-left: 0rem !important;
}
.margin-left {
  margin-top: 0rem !important;
  margin-right: 0rem !important;
  margin-bottom: 0rem !important;
}
.padding-left {
  padding-top: 0rem !important;
  padding-right: 0rem !important;
  padding-bottom: 0rem !important;
}
.margin-horizontal {
  margin-top: 0rem !important;
  margin-bottom: 0rem !important;
}
.padding-horizontal {
  padding-top: 0rem !important;
  padding-bottom: 0rem !important;
}
.margin-vertical {
  margin-right: 0rem !important;
  margin-left: 0rem !important;
}
.padding-vertical {
  padding-right: 0rem !important;
  padding-left: 0rem !important;
}
.balanced {
  max-inline-size: 50ch;
  text-wrap: balance;
}
/* Apply "..." at 100% width */
.truncate-width { 
		width: 100%; 
    white-space: nowrap; 
    overflow: hidden; 
    text-overflow: ellipsis; 
}
/* Removes native scrollbar */
.no-scrollbar {
    -ms-overflow-style: none;
    overflow: -moz-scrollbars-none; 
}
.no-scrollbar::-webkit-scrollbar {
    display: none;
}
</style>
    </div>
    <main class="main-wrapper">
      <slot />
    </main>
  </div>
  <script is:inline src="https://d3e54v103j8qbb.cloudfront.net/js/jquery-3.5.1.min.dc5e7f18c8.js?site=66edbd3a1299d20d06f1a5e4" type="text/javascript" integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0=" crossorigin="anonymous"></script>
  <script is:inline src="/webflow/js/webflow.js" type="text/javascript"></script>
  <script is:inline>
document.addEventListener("DOMContentLoaded", (event) => {
const RiveModule = window.Webflow.require('rive'); const myAnimation = document.getElementsByClassName("hexagons"); const instance = RiveModule.getInstance(myAnimation); const r = instance.rive; function computeSize() {       r.resizeDrawingSurfaceToCanvas(); }
});
</script>
  <script is:inline>
  (function () {
    const COOKIE_NAME = "user_subscribed";
    const COOKIE_DURATION_DAYS = 365;
    function setCookie(name, value, days) {
      const expires = new Date(Date.now() + days * 864e5).toUTCString();
      document.cookie = `${name}=${encodeURIComponent(value)}; expires=${expires}; path=/`;
    }
    function getCookie(name) {
      return document.cookie
        .split("; ")
        .reduce((r, v) => {
          const parts = v.split("=");
          return parts[0] === name ? decodeURIComponent(parts[1]) : r;
        }, null);
    }
    function showElement(attr) {
      document.querySelectorAll(`[${attr}]`).forEach(el => el.style.display = "block");
    }
    function hideElement(attr) {
      document.querySelectorAll(`[${attr}]`).forEach(el => el.style.display = "none");
    }
    function updateVisibility() {
      const hasCookie = getCookie(COOKIE_NAME);
      if (hasCookie) {
        showElement("show-welcome");
        hideElement("show-subscribe");
      } else {
        showElement("show-subscribe");
        hideElement("show-welcome");
      }
    }
    function handleRedirectCookieSet() {
      const path = window.location.pathname;
      const welcomePaths = ["/composer-welcome", "/welcome"];
      if (welcomePaths.includes(path)) {
        setCookie(COOKIE_NAME, "true", COOKIE_DURATION_DAYS);
      }
    }
    document.addEventListener("DOMContentLoaded", function () {
      handleRedirectCookieSet();
      updateVisibility();
    });
  })();
</script>
</body>
</html>
