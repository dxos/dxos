---
import WebflowLayout from '../layouts/WebflowLayout.astro';
import WebflowNav from '../components/WebflowNav.astro';
import WebflowFooter from '../components/WebflowFooter.astro';
import IconChevronRight from '../components/svg/IconChevronRight.astro';
import IconExternalLink from '../components/svg/IconExternalLink.astro';
import IconGitHub from '../components/svg/IconGitHub.astro';
import IconDiscord from '../components/svg/IconDiscord.astro';
import IconX from '../components/svg/IconX.astro';
---
<WebflowLayout
  title="Composer by DXOS"
  description="Introducing programmable documents. Blend the power of popular file formats (docs, sheets, sketch &amp; tables) inside of a collaborative local-first workspace."
  ogImage="/webflow/images/dxos-composer-og-image.png"
  wfPageId="66fab71bdf95a9e03ee9018b"
>
  <WebflowNav currentPage="composer" />
      <div id="top" class="section_composer-hero">
        <div class="container-large">
          <div class="masthead-wrap left-align">
            <div class="all-caps is-blue">Composer by DXOS</div>
            <h1 blocks-non-deletable="true" class="heading-style-h1">Introducing <span class="heading-highlight composer">programmable</span> documents</h1>
            <p class="text-size-large text-style-muted">To show off the power of DXOS, we&#x27;ve built Composer. A local-first workspace that is designed for small team collaboration.</p>
            <div class="button-group">
              <div class="div-block-29">
                <div show-subscribe="" class="show-subscribe">
                  <div set-subscribe-cookie="" class="form-block w-form">
                    <form id="wf-form-Early-access" name="wf-form-Early-access" data-name="Early-access" redirect="/composer-welcome" data-redirect="/composer-welcome" method="post" class="early-access-form" data-wf-page-id="66fab71bdf95a9e03ee9018b" data-wf-element-id="45bd54de-42f6-1ba6-4ed5-39d157bbf0d4"><input class="form-input w-input" maxlength="256" name="Email" data-name="Email" placeholder="Email" type="email" id="Email" required=""><input type="submit" data-wait="Please wait..." set-subscribe-cookie="" data-w-id="45bd54de-42f6-1ba6-4ed5-39d157bbf0d6" class="button is-secondary w-button" value="Request Access"></form>
                    <div class="success-message w-form-done">
                      <div>Thank you! Check your email to confirm your address</div>
                    </div>
                    <div class="error-message w-form-fail">
                      <div>Oops! Something went wrong while submitting the form.</div>
                    </div>
                  </div>
                </div>
                <div show-welcome="" class="show-welcome">
                  <div class="welcome-grid_card">
                    <div class="card-text-wrapper">
                      <div class="heading-style-h5">You&#x27;re on the list! </div>
                      <div class="text-style-muted balanced">Please check your email to confirm your subscription. </div>
                    </div>
                    <a data-w-id="d62d14e8-33a4-86a7-ca92-681e94fce8b4" href="composer-welcome.html" class="button is-secondary w-inline-block">
                      <div>Welcome </div>
                      <div class="icon-1x1-xxsmall nav-arrow w-embed"><IconExternalLink /></div>
                    </a>
                    <div class="spacer-small"></div>
                    <div class="display-inlineflex hide-mobile">
                      <a href="https://github.com/dxos" target="_blank" class="button is-link is-icon-only c w-inline-block">
                        <div class="icon-1x1-xsmall w-embed"><IconGitHub /></div>
                      </a>
                      <a href="https://discord.gg/eXVfryv3sW" target="_blank" class="button is-link is-icon-only c w-inline-block">
                        <div class="icon-1x1-xsmall w-embed"><IconDiscord /></div>
                      </a>
                      <a href="https://x.com/dxos_org" target="_blank" class="button is-link is-icon-only c w-inline-block">
                        <div class="icon-1x1-xsmall w-embed"><IconX /></div>
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="section-hero_lower-cta composer">
          <a href="/" class="button is-link w-inline-block">
            <div>Powered by DXOS</div>
            <div class="icon-embed-xsmall w-embed">
              <IconChevronRight />
            </div>
          </a>
        </div>
        <div class="composer-hero-bkg-wrap"><img src="/webflow/images/Composer-home-hero-rings.webp" loading="lazy" sizes="(max-width: 1170px) 100vw, 1170px" srcset="/webflow/images/Composer-home-hero-rings-p-500.png 500w, /webflow/images/Composer-home-hero-rings-p-800.png 800w, /webflow/images/Composer-home-hero-rings-p-1080.png 1080w, /webflow/images/Composer-home-hero-rings.webp 1170w" alt="" class="composer-ring-element"></div>
      </div>
      <div class="section_partners">
