              <a href="https://socketsupply.co/" target="_blank" class="partner-logo-wrap w-inline-block"><img src="/webflow/images/SocketSupply.png" loading="lazy" alt="Socket Supply logo" class="partner-logo"></a>
              <a href="https://effect.website/" target="_blank" class="partner-logo-wrap w-inline-block"><img src="/webflow/images/Effect.png" loading="lazy" alt="Effect logo" class="partner-logo"></a>
            </div>
          </div>
        </div>
      </div>
      <div>
        <div class="section_grid">
          <div class="container-large">
            <div class="w-layout-grid feature-grid _4col">
              <div id="w-node-_41002e10-b86a-cbf8-2679-4685cb45b6ab-cb45b6a7" class="dxos_stack-header no-bottom-line">
                <div class="all-caps is-blue">Product</div>
                <div class="heading-style-h2">Meet Composer</div>
              </div>
              <div id="w-node-_41002e10-b86a-cbf8-2679-4685cb45b6b0-cb45b6a7" class="dxos_stack-header no-bottom-line right">
                <div class="text-style-muted">Composer blends the power of popular file formats (docs, sheets, sketch &amp; tables) while allowing you to build plugins, deploy custom functions and leverage modern LLM&#x27;s</div>
              </div>
              <div id="w-node-_41002e10-b86a-cbf8-2679-4685cb45b6b3-cb45b6a7" class="horizontal-line-wrap">
                <div class="horiozontal-line full"></div>
              </div>
              <div id="w-node-_41002e10-b86a-cbf8-2679-4685cb45b6b5-cb45b6a7" class="dxos_stack-card top">
                <div class="image-highlight-gradient"><img src="/webflow/images/Docs-example-card-no-border.png" loading="lazy" alt=""></div>
                <div class="card-text-wrapper">
                  <div class="heading-style-h5">Docs</div>
                  <div class="text-style-muted">Enjoy realtime collaboration inside of a modern markdown editor.</div>
                </div>
                <div class="card-bkg-gradient-blur-wrap">
                  <div class="card-bkg-gradient-blur"></div>
                </div>
              </div>
              <div id="w-node-_41002e10-b86a-cbf8-2679-4685cb45b6bf-cb45b6a7" class="dxos_stack-card comments">
