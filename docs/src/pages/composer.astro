                  <div class="heading-style-h5">Threaded comments</div>
                  <div class="text-style-muted">Collaborate with threaded comments across multiple document formats.</div>
                </div>
                <div class="card-bkg-gradient-blur-wrap right">
                  <div class="card-bkg-gradient-blur"></div>
