{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": null,
  "categories": {},
  "rules": {
    "no-unused-vars": "off",
    "eslint/no-async-promise-executor": "off",
    "eslint/no-constant-binary-expression": "off",
    "eslint/no-constant-condition": "off",
    "eslint/no-dupe-else-if": "off",
    "eslint/no-unassigned-vars": "off",
    "eslint/no-unsafe-optional-chaining": "off",
    "eslint/no-unused-expressions": "off",
    "eslint/no-unused-private-class-members": "off",
    "eslint/no-useless-catch": "off",
    "eslint/no-useless-escape": "off",
    "eslint/no-useless-rename": "off",
    "eslint/require-yield": "off",
    "unicorn/no-await-in-promise-methods": "off",
    "unicorn/no-empty-file": "off",
    "unicorn/no-new-array": "off",
    "unicorn/no-single-promise-in-promise-methods": "off",
    "unicorn/no-thenable": "off",
    "unicorn/no-useless-fallback-in-spread": "off",
    "unicorn/no-useless-spread": "off",
    "unicorn/prefer-string-starts-ends-with": "off",
    "oxc/only-used-in-recursion": "off",
    "typescript/no-this-alias": "off",
    "typescript/no-unnecessary-parameter-property-assignment": "off",
    "typescript/no-useless-empty-export": "off",
    "@dxos/eslint-plugin-rules/effect-subpath-imports": "error",
    "@dxos/eslint-plugin-rules/header": "error",
    "@dxos/eslint-plugin-rules/no-bare-dot-imports": "error",
    "@dxos/eslint-plugin-rules/no-effect-run-promise": "error",
    "@dxos/eslint-plugin-rules/no-empty-promise-catch": "error"
  },
  "settings": {
    "jsx-a11y": {
      "polymorphicPropName": null,
      "components": {},
      "attributes": {}
    },
    "react": {
      "formComponents": [],
      "linkComponents": [],
      "version": null,
      "componentWrapperFunctions": []
    },
    "jsdoc": {
      "ignorePrivate": false,
      "ignoreInternal": false,
      "ignoreReplacesDocs": true,
      "overrideReplacesDocs": true,
      "augmentsExtendsReplacesDocs": false,
      "implementsReplacesDocs": false,
      "exemptDestructuredRootsFromChecks": false,
      "tagNamePreference": {}
    },
    "vitest": {
      "typecheck": false
    }
  },
  "env": {
    "builtin": true
  },
  "globals": {},
  "ignorePatterns": [
    "templates/**",
    "scripts/**",
    "**/typings/**",
    "tools/swc-log-plugin/tests/__swc_snapshots__/**",
    ".idea/**",
    ".vscode/**",
    ".claude/**",
    "docs",
    "**/gen/**",
    "**/tailwind.ts"
  ],
  "jsPlugins": [
    "@dxos/eslint-plugin-rules"
  ]
}