{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "composer-crx",
      "runtimeExecutable": "moon",
      "runtimeArgs": ["run", "composer-crx:serve"],
      "port": 5173
    },
    {
      "name": "composer-app",
      "runtimeExecutable": "moon",
      "runtimeArgs": ["run", "composer-app:serve", "--", "--port", "5180", "--strictPort"],
      "port": 5180,
      "autoPort": true
    },
    {
      "name": "testbench-app",
      "runtimeExecutable": "moon",
      "runtimeArgs": ["run", "testbench-app:serve"],
      "port": 5173
    },
    {
      "name": "tasks-app",
      "runtimeExecutable": "moon",
      "runtimeArgs": ["run", "tasks:serve"],
      "port": 5173
    },
    {
      "name": "todomvc-preview",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@dxos/todomvc", "exec", "vite", "preview", "--port", "4173"],
      "port": 4173,
      "autoPort": true
    },
    {
      "name": "storybook-react",
      "runtimeExecutable": "moon",
      "runtimeArgs": ["run", "storybook-react:serve"],
      "port": 9009
    },
    {
      "name": "plugin-explorer-storybook",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@dxos/plugin-explorer", "exec", "storybook", "dev", "--port", "9010", "--no-open"],
      "port": 9010
    },
    {
      "name": "plugin-map-storybook",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@dxos/plugin-map", "exec", "storybook", "dev", "--port", "9010", "--no-open"],
      "port": 9010
    },
    {
      "name": "plugin-preview-storybook",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@dxos/plugin-preview", "exec", "storybook", "dev", "--port", "9011", "--no-open"],
      "port": 9011,
      "autoPort": true
    },
    {
      "name": "docs",
      "runtimeExecutable": "moon",
      "runtimeArgs": ["run", "docs:serve"],
      "port": 4321
    }
  ]
}
