{
  "name": "@dxos/react-client",
  "version": "0.10.0",
  "description": "React client API",
  "homepage": "https://dxos.org",
  "bugs": "https://github.com/dxos/dxos/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/dxos/dxos"
  },
  "license": "FSL-1.1-Apache-2.0",
  "author": "DXOS.org",
  "sideEffects": false,
  "type": "module",
  "exports": {
    "./devtools": {
      "source": "./src/devtools/index.ts",
      "types": "./dist/types/src/devtools/index.d.ts",
      "import": "./dist/lib/devtools.mjs"
    },
    "./echo": {
      "source": "./src/echo/index.ts",
      "types": "./dist/types/src/echo/index.d.ts",
      "import": "./dist/lib/echo.mjs"
    },
    "./halo": {
      "source": "./src/halo/index.ts",
      "types": "./dist/types/src/halo/index.d.ts",
      "import": "./dist/lib/halo.mjs"
    },
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/types/src/index.d.ts",
      "import": "./dist/lib/index.mjs"
    },
    "./invitations": {
      "source": "./src/invitations/index.ts",
      "types": "./dist/types/src/invitations/index.d.ts",
      "import": "./dist/lib/invitations.mjs"
    },
    "./mesh": {
      "source": "./src/mesh/index.ts",
      "types": "./dist/types/src/mesh/index.d.ts",
      "import": "./dist/lib/mesh.mjs"
    },
    "./testing": {
      "source": "./src/testing/index.ts",
      "types": "./dist/types/src/testing/index.d.ts",
      "import": "./dist/lib/testing.mjs"
    }
  },
  "types": "dist/types/src/index.d.ts",
  "scripts": {
    "typedoc": "typedoc --out typedoc"
  },
  "dependencies": {
    "@dxos/async": "workspace:*",
    "@dxos/client": "workspace:*",
    "@dxos/codec-protobuf": "workspace:*",
    "@dxos/config": "workspace:*",
    "@dxos/context": "workspace:*",
    "@dxos/debug": "workspace:*",
    "@dxos/echo": "workspace:*",
    "@dxos/echo-protocol": "workspace:*",
    "@dxos/echo-react": "workspace:*",
    "@dxos/invariant": "workspace:*",
    "@dxos/keys": "workspace:*",
    "@dxos/log": "workspace:*",
    "@dxos/node-std": "workspace:*",
    "@dxos/react-hooks": "workspace:*",
    "@dxos/util": "workspace:*"
  },
  "devDependencies": {
    "@dxos/random": "workspace:*",
    "@dxos/react-ui": "workspace:*",
    "@dxos/react-ui-syntax-highlighter": "workspace:*",
    "@dxos/storybook-utils": "workspace:*",
    "@dxos/test-utils": "workspace:*",
    "@dxos/ui-theme": "workspace:*",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typedoc": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "optionalDependencies": {
    "@dxos/random": "workspace:*",
    "@dxos/react-ui": "workspace:*",
    "@dxos/ui-theme": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "typedoc": {
    "entryPoint": "src/index.ts"
  }
}
