// Local, moon-free typecheck (experimental branch): no project references, so the edge-client →
// compute/echo → … → client-services cycle doesn't block `tsc`. @dxos deps resolve to their built
// dist/types via node_modules. Not built; not part of CI.
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "incremental": false,
    "noEmit": true,
    "emitDeclarationOnly": false,
    "disableSourceOfProjectReferenceRedirect": true
  },
  "references": []
}
