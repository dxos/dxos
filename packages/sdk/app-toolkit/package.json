{
  "name": "@dxos/app-toolkit",
  "version": "0.10.0",
  "description": "Composer-specific capabilities, plugin helpers, and playground for building Composer plugins.",
  "homepage": "https://dxos.org",
  "bugs": "https://github.com/dxos/dxos/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/dxos/dxos"
  },
  "license": "FSL-1.1-Apache-2.0",
  "author": "DXOS.org",
  "sideEffects": [
    "./src/ui/**",
    "./dist/lib/**/ui/**"
  ],
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/types/src/index.d.ts",
      "import": "./dist/lib/index.mjs"
    },
    "./workerd": {
      "types": "./dist/types/src/index.d.ts",
      "default": "./dist/lib/browser/index.mjs"
    },
    "./events": {
      "source": "./src/app-framework/AppActivationEvents.ts",
      "types": "./dist/types/src/app-framework/AppActivationEvents.d.ts",
      "import": "./dist/lib/app-framework/AppActivationEvents.mjs"
    },
    "./query": {
      "source": "./src/echo/Query.ts",
      "types": "./dist/types/src/echo/Query.d.ts",
      "import": "./dist/lib/echo/Query.mjs"
    },
    "./ui": {
      "source": "./src/ui/index.ts",
      "types": "./dist/types/src/ui/index.d.ts",
      "import": "./dist/lib/ui.mjs"
    }
  },
  "types": "dist/types/src/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@atlaskit/pragmatic-drag-and-drop-hitbox": "catalog:",
    "@dxos/ai": "workspace:*",
    "@dxos/app-framework": "workspace:*",
    "@dxos/app-graph": "workspace:*",
    "@dxos/client": "workspace:*",
    "@dxos/client-protocol": "workspace:*",
    "@dxos/compute": "workspace:*",
    "@dxos/echo": "workspace:*",
    "@dxos/effect": "workspace:*",
    "@dxos/errors": "workspace:*",
    "@dxos/i18n": "workspace:*",
    "@dxos/invariant": "workspace:*",
    "@dxos/keyboard": "workspace:*",
    "@dxos/keys": "workspace:*",
    "@dxos/log": "workspace:*",
    "@dxos/progress": "workspace:*",
    "@dxos/react-client": "workspace:*",
    "@dxos/react-ui": "workspace:*",
    "@dxos/react-ui-attention": "workspace:*",
    "@dxos/react-ui-list": "workspace:*",
    "@dxos/react-ui-menu": "workspace:*",
    "@dxos/schema": "workspace:*",
    "@dxos/types": "workspace:*",
    "@dxos/ui-theme": "workspace:*",
    "@dxos/util": "workspace:*",
    "@effect/cli": "catalog:",
    "@tauri-apps/api": "catalog:"
  },
  "devDependencies": {
    "@automerge/automerge": "catalog:",
    "@dxos/echo-client": "workspace:*",
    "@dxos/react-ui": "workspace:*",
    "@dxos/react-ui-syntax-highlighter": "workspace:*",
    "@dxos/storybook-utils": "workspace:*",
    "@dxos/ui-theme": "workspace:*",
    "@effect-atom/atom-react": "catalog:",
    "@types/react": "catalog:",
    "effect": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "peerDependencies": {
    "@effect-atom/atom-react": "catalog:",
    "effect": "catalog:",
    "react": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
