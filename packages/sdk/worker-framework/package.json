{
  "name": "@dxos/worker-framework",
  "version": "0.10.0",
  "description": "Generic worker management framework for DXOS client services.",
  "homepage": "https://dxos.org",
  "bugs": "https://github.com/dxos/dxos/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/dxos/dxos"
  },
  "license": "FSL-1.1-Apache-2.0",
  "author": "DXOS.org",
  "sideEffects": true,
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/types/src/index.d.ts",
      "browser": "./dist/lib/browser/index.mjs",
      "node": "./dist/lib/node-esm/index.mjs"
    },
    "./client": {
      "source": "./src/client/index.ts",
      "types": "./dist/types/src/client/index.d.ts",
      "browser": "./dist/lib/browser/client/index.mjs",
      "node": "./dist/lib/node-esm/client/index.mjs"
    },
    "./worker": {
      "source": "./src/worker/index.ts",
      "types": "./dist/types/src/worker/index.d.ts",
      "browser": "./dist/lib/browser/worker/index.mjs",
      "node": "./dist/lib/node-esm/worker/index.mjs"
    },
    "./coordinator": {
      "source": "./src/coordinator/index.ts",
      "types": "./dist/types/src/coordinator/index.d.ts",
      "browser": "./dist/lib/browser/coordinator/index.mjs",
      "node": "./dist/lib/node-esm/coordinator/index.mjs"
    }
  },
  "types": "dist/types/src/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@dxos/async": "workspace:*",
    "@dxos/context": "workspace:*",
    "@dxos/effect": "workspace:*",
    "@dxos/invariant": "workspace:*",
    "@dxos/log": "workspace:*",
    "@dxos/util": "workspace:*",
    "@effect-atom/atom": "catalog:",
