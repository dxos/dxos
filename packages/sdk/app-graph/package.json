{
  "name": "@dxos/app-graph",
  "version": "0.10.0",
  "description": "Constructs knowledge graphs for the purpose of building applications on top of",
  "homepage": "https://dxos.org",
  "bugs": "https://github.com/dxos/dxos/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/dxos/dxos"
  },
  "license": "FSL-1.1-Apache-2.0",
  "author": "DXOS.org",
  "sideEffects": false,
  "type": "module",
  "imports": {
    "#scheduler": {
      "source": {
        "browser": "./src/scheduler.browser.ts",
        "default": "./src/scheduler.ts"
      },
      "types": "./dist/types/src/scheduler.d.ts",
      "default": "./dist/lib/scheduler.mjs"
    }
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/types/src/index.d.ts",
      "import": "./dist/lib/index.mjs"
    },
    "./testing": {
      "source": "./src/testing/index.ts",
      "types": "./dist/types/src/testing/index.d.ts",
      "import": "./dist/lib/testing.mjs"
    }
  },
  "types": "dist/types/src/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@dxos/async": "workspace:*",
    "@dxos/debug": "workspace:*",
    "@dxos/echo": "workspace:*",
    "@dxos/invariant": "workspace:*",
    "@dxos/keys": "workspace:*",
    "@dxos/log": "workspace:*",
    "@dxos/util": "workspace:*",
    "main-thread-scheduling": "catalog:"
  },
  "devDependencies": {
    "@dxos/random": "workspace:*",
    "@dxos/react-client": "workspace:*",
    "@dxos/react-ui": "workspace:*",
    "@dxos/react-ui-list": "workspace:*",
    "@dxos/react-ui-tabs": "workspace:*",
    "@dxos/storybook-utils": "workspace:*",
    "@dxos/ui-theme": "workspace:*",
    "@effect-atom/atom-react": "catalog:",
    "@effect/platform": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "effect": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "vite": "catalog:"
  },
  "peerDependencies": {
    "@dxos/react-ui": "workspace:^",
    "@dxos/ui-theme": "workspace:^",
    "@effect-atom/atom-react": "catalog:",
    "@effect/platform": "catalog:",
    "effect": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
