{
  "name": "@dxos/config",
  "version": "0.10.0",
  "description": "Config utilities",
  "homepage": "https://dxos.org",
  "bugs": "https://github.com/dxos/dxos/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/dxos/dxos"
  },
  "license": "FSL-1.1-Apache-2.0",
  "author": "DXOS.org",
  "sideEffects": false,
  "type": "module",
  "imports": {
    "#loaders": {
      "source": {
        "browser": "./src/loaders/browser.ts",
        "default": "./src/loaders/index.ts"
      },
      "types": "./dist/types/src/loaders/index.d.ts",
      "browser": "./dist/lib/loaders/browser.mjs",
      "default": "./dist/lib/loaders/index.mjs"
    },
    "#savers": {
      "source": {
        "browser": "./src/savers/browser.ts",
        "default": "./src/savers/index.ts"
      },
      "types": "./dist/types/src/savers/index.d.ts",
      "browser": "./dist/lib/savers/browser.mjs",
      "default": "./dist/lib/savers/index.mjs"
    },
    "#plugin": {
      "source": {
        "browser": "./src/plugin/browser.ts",
        "default": "./src/plugin/index.ts"
      },
      "types": "./dist/types/src/plugin/index.d.ts",
      "browser": "./dist/lib/plugin/browser.mjs",
      "default": "./dist/lib/plugin/index.mjs"
    }
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/types/src/index.d.ts",
      "import": "./dist/lib/index.mjs"
    },
    "./esbuild-plugin": {
      "source": "./src/plugin/esbuild-plugin.ts",
      "types": "./dist/types/src/plugin/esbuild-plugin.d.ts",
      "import": "./dist/lib/plugin/esbuild-plugin.mjs"
    },
    "./rollup-plugin": {
      "source": "./src/plugin/rollup-plugin.ts",
      "types": "./dist/types/src/plugin/rollup-plugin.d.ts",
      "import": "./dist/lib/plugin/rollup-plugin.mjs"
    },
    "./vite-plugin": {
      "source": "./src/plugin/vite-plugin.ts",
      "types": "./dist/types/src/plugin/vite-plugin.d.ts",
      "import": "./dist/lib/plugin/vite-plugin.mjs"
    }
  },
  "main": "dist/lib/node/index.cjs",
  "types": "dist/types/src/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "test-build": "node ./src/testing/build.js"
  },
  "dependencies": {
    "@dxos/client-protocol": "workspace:*",
    "@dxos/invariant": "workspace:*",
    "@dxos/log": "workspace:*",
    "@dxos/node-std": "workspace:*",
    "@dxos/protocols": "workspace:*",
    "@dxos/tracing": "workspace:*",
    "@dxos/util": "workspace:*",
    "@effect/platform": "catalog:",
    "effect": "catalog:",
    "localforage": "catalog:",
    "lodash.defaultsdeep": "catalog:",
    "lodash.ismatch": "catalog:",
    "pkg-up": "catalog:",
    "yaml": "catalog:"
  },
  "devDependencies": {
    "@types/lodash.defaultsdeep": "catalog:",
    "@types/lodash.ismatch": "catalog:",
    "webpack": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  },
  "typedoc": {
    "entryPoint": "src/index.ts"
  }
}
