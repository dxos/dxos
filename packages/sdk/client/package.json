      "source": "./src/invitations/index.ts",
      "types": "./dist/types/src/invitations/index.d.ts",
      "import": "./dist/lib/invitations.mjs"
    },
    "./mesh": {
      "source": "./src/mesh/index.ts",
      "types": "./dist/types/src/mesh/index.d.ts",
      "import": "./dist/lib/mesh.mjs"
    },
    "./testing": {
      "source": "./src/testing/index.ts",
      "types": "./dist/types/src/testing/index.d.ts",
      "import": "./dist/lib/testing.mjs"
