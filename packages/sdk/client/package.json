    },
    "./dedicated-worker": {
      "source": "./src/services/dedicated/dedicated-worker-entrypoint.ts",
      "types": "./dist/types/src/services/dedicated/dedicated-worker-entrypoint.d.ts",
      "import": "./dist/lib/services/dedicated/dedicated-worker-entrypoint.mjs"
    },
    "./coordinator-worker": {
      "source": "./src/services/dedicated/coordinator-worker-entrypoint.ts",
      "types": "./dist/types/src/services/dedicated/coordinator-worker-entrypoint.d.ts",
      "import": "./dist/lib/services/dedicated/coordinator-worker-entrypoint.mjs"
    }
  },
  "types": "dist/types/src/index.d.ts",
  "files": [
    "dist",
    "src"
