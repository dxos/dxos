    "fast-deep-equal": "catalog:",
    "jwt-decode": "catalog:",
    "lodash.isequalwith": "catalog:"
  },
  "devDependencies": {
    "@automerge/automerge": "catalog:",
    "@types/lodash.isequalwith": "catalog:",
    "typedoc": "catalog:"
  },
  "peerDependencies": {
    "effect": "catalog:"
  },
  "engines": {
    "node": ">=12.0.0"
  },
