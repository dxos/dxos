      "source": "./src/worker/opfs-worker.ts",
      "types": "./dist/types/src/worker/opfs-worker.d.ts",
      "browser": "./dist/lib/worker/opfs-worker.mjs"
    },
    "#coordinator-worker": {
      "source": "./src/services/dedicated/coordinator-worker-entrypoint.ts",
      "types": "./dist/types/src/services/dedicated/coordinator-worker-entrypoint.d.ts",
      "browser": "./dist/lib/services/dedicated/coordinator-worker-entrypoint.mjs",
      "node": "./dist/lib/services/dedicated/coordinator-worker-entrypoint.mjs"
    }
  },
  "exports": {
    "./devtools": {
      "source": "./src/devtools/index.ts",
      "types": "./dist/types/src/devtools/index.d.ts",
      "import": "./dist/lib/devtools.mjs"
    },
    "./echo": {
      "source": "./src/echo/index.ts",
      "types": "./dist/types/src/echo/index.d.ts",
      "import": "./dist/lib/echo.mjs"
