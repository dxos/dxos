    "@dxos/network-manager": "workspace:*",
    "@dxos/node-std": "workspace:*",
    "@dxos/protocols": "workspace:*",
    "@dxos/random-access-storage": "workspace:*",
    "@dxos/rpc": "workspace:*",
    "@dxos/rpc-tunnel": "workspace:*",
