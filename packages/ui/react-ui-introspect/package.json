{
  "name": "@dxos/react-ui-introspect",
  "version": "0.9.0",
  "private": true,
  "description": "React UI for browsing and invoking the introspect-mcp tool surface.",
  "homepage": "https://dxos.org",
  "bugs": "https://github.com/dxos/dxos/issues",
