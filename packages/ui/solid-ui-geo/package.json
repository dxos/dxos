{
  "name": "@dxos/solid-ui-geo",
  "version": "0.10.0",
  "description": "Geo components for SolidJS.",
  "homepage": "https://github.com/dxos",
  "bugs": "https://github.com/dxos/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/dxos/dxos"
  },
  "license": "FSL-1.1-Apache-2.0",
  "author": "DXOS.org",
  "sideEffects": true,
  "type": "module",
  "imports": {
    "#translations": "./src/translations.ts"
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/types/src/index.d.ts",
      "import": "./dist/lib/index.mjs"
    },
    "./data": {
      "source": "./src/data.ts",
      "types": "./dist/types/src/data.d.ts",
      "import": "./dist/lib/data.mjs"
    },
    "./translations": {
      "source": "./src/translations.ts",
      "types": "./dist/types/src/translations.d.ts",
      "import": "./dist/lib/translations.mjs"
    }
  },
  "types": "dist/types/src/index.d.ts",
  "files": [
    "data",
    "dist",
    "src"
  ],
  "dependencies": {
    "@dxos/async": "workspace:*",
    "@dxos/debug": "workspace:*",
    "@dxos/log": "workspace:*",
    "@dxos/node-std": "workspace:*",
    "@dxos/ui-theme": "workspace:*",
    "@dxos/util": "workspace:*",
    "@solid-primitives/resize-observer": "^2.0.26",
    "d3": "catalog:",
    "d3-geo-projection": "catalog:",
    "d3-hexbin": "catalog:",
    "geojson": "catalog:",
    "leaflet": "catalog:",
    "lodash.defaultsdeep": "catalog:",
    "solid-element": "catalog:",
    "topojson-client": "catalog:",
    "topojson-simplify": "catalog:",
    "versor": "catalog:"
  },
  "devDependencies": {
    "@dxos/storybook-utils": "workspace:*",
    "@solidjs/testing-library": "catalog:",
    "@types/d3": "catalog:",
    "@types/geojson": "catalog:",
    "@types/leaflet": "catalog:",
    "@types/topojson-client": "catalog:",
    "@types/topojson-simplify": "catalog:",
    "@types/topojson-specification": "catalog:",
    "JSONStream": "catalog:",
    "geojson2h3": "catalog:",
    "solid-js": "catalog:",
    "vite-plugin-solid": "catalog:"
  },
  "peerDependencies": {
    "solid-js": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
