{
  "name": "@dxos/log",
  "version": "0.10.0",
  "description": "Logger",
  "homepage": "https://dxos.org",
  "bugs": "https://github.com/dxos/dxos/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/dxos/dxos"
  },
  "license": "FSL-1.1-Apache-2.0",
  "author": "DXOS.org",
  "sideEffects": true,
  "type": "module",
  "imports": {
    "#platform": {
      "source": {
        "browser": "./src/platform/browser/index.ts",
        "default": "./src/platform/node/index.ts"
      },
      "types": "./dist/types/src/platform/node/index.d.ts",
      "browser": "./dist/lib/platform/browser.mjs",
      "default": "./dist/lib/platform/node.mjs"
    },
    "#console-processor": {
      "source": {
        "browser": "./src/processors/console-stub.ts",
        "default": "./src/processors/console-processor.ts"
      },
      "types": "./dist/types/src/processors/console-processor.d.ts",
      "browser": "./dist/lib/processors/console-stub.mjs",
      "default": "./dist/lib/processors/console-processor.mjs"
    }
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/types/src/index.d.ts",
      "import": "./dist/lib/index.mjs"
    },
    "./file-processor": {
      "source": "./src/processors/file-processor.ts",
      "types": "./dist/types/src/processors/file-processor.d.ts",
      "import": "./dist/lib/processors/file-processor.mjs"
    }
  },
  "types": "dist/types/src/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@dxos/node-std": "workspace:*",
    "@dxos/util": "workspace:*",
    "chalk": "catalog:",
    "js-yaml": "catalog:",
    "lodash.defaultsdeep": "catalog:"
  },
  "devDependencies": {
    "@types/js-yaml": "catalog:",
    "@types/lodash.defaultsdeep": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
