{
  "name": "@dxos/introspect-mcp",
  "version": "0.10.0",
  "description": "MCP server exposing DXOS monorepo introspection.",
  "homepage": "https://dxos.org",
  "bugs": "https://github.com/dxos/dxos/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/dxos/dxos"
  },
  "license": "FSL-1.1-Apache-2.0",
  "author": "info@dxos.org",
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/types/src/index.d.ts",
      "import": "./dist/lib/index.mjs"
    },
    "./tools": {
      "source": "./src/tools/index.ts",
      "types": "./dist/types/src/tools/index.d.ts",
      "import": "./dist/lib/tools.mjs"
    }
  },
  "bin": {
    "dx-introspect-mcp": "./bin/dx-introspect-mcp.mjs"
  },
  "files": [
    "bin",
    "dist",
    "src"
  ],
  "scripts": {
    "start": "tsx --conditions=source src/cli.ts"
  },
  "dependencies": {
    "@dxos/effect-zod": "workspace:*",
    "@dxos/introspect": "workspace:*",
    "@dxos/introspect-tools": "workspace:*",
    "@dxos/log": "workspace:*",
    "@dxos/util": "workspace:*",
    "@modelcontextprotocol/sdk": "catalog:",
    "effect": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
