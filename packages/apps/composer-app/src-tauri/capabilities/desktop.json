{
  "identifier": "desktop-capability",
  "platforms": ["macOS"],
  "windows": ["main", "popover"],
  "remote": {
    "urls": ["http://localhost:26777/*"]
  },
  "permissions": [
    "core:default",
    "core:window:allow-set-focus",
    "core:window:allow-show",
    "core:window:allow-start-dragging",
    "deep-link:default",
    "dialog:default",
    "dialog:allow-open",
    "fs:read-all",
    {
      "identifier": "fs:allow-watch",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "**" }, { "path": "**/.composer" }, { "path": "**/.composer/**" }]
    },
    "fs:write-all",
    "macos-passkey:default",
    "process:default",
    "shell:allow-open",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "args": ["serve"],
          "name": "sidecar/ollama",
          "sidecar": true
        }
      ]
    },
    "updater:default"
  ]
}
