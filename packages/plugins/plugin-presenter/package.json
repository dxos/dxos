{
  "name": "@dxos/plugin-presenter",
  "version": "0.10.0",
  "description": "Braneframe presenter plugin",
  "homepage": "https://dxos.org",
  "bugs": "https://github.com/dxos/dxos/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/dxos/dxos"
  },
  "license": "FSL-1.1-Apache-2.0",
  "author": "DXOS.org",
  "sideEffects": true,
  "type": "module",
  "imports": {
    "#capabilities": {
      "source": "./src/capabilities/index.ts",
      "types": "./dist/types/src/capabilities/index.d.ts",
      "default": "./dist/lib/capabilities/index.mjs"
    },
    "#components": {
      "source": "./src/components/index.ts",
      "types": "./dist/types/src/components/index.d.ts",
      "default": "./dist/lib/components/index.mjs"
    },
    "#containers": {
      "source": "./src/containers/index.ts",
      "types": "./dist/types/src/containers/index.d.ts",
      "default": "./dist/lib/containers/index.mjs"
    },
    "#meta": {
      "source": "./src/meta.ts",
      "types": "./dist/types/src/meta.d.ts",
      "default": "./dist/lib/meta.mjs"
    },
    "#operations": {
      "source": "./src/operations/index.ts",
      "types": "./dist/types/src/operations/index.d.ts",
      "default": "./dist/lib/operations/index.mjs"
    },
    "#plugin": {
      "source": {
        "workerd": "./src/PresenterPlugin.workerd.ts",
        "node": "./src/PresenterPlugin.node.ts",
        "default": "./src/PresenterPlugin.tsx"
      },
      "types": "./dist/types/src/PresenterPlugin.d.ts",
      "workerd": "./dist/lib/PresenterPlugin.workerd.mjs",
      "node": "./dist/lib/PresenterPlugin.node.mjs",
      "default": "./dist/lib/PresenterPlugin.mjs"
    },
    "#testing": "./src/testing.ts",
    "#translations": {
      "source": "./src/translations.ts",
      "types": "./dist/types/src/translations.d.ts",
      "default": "./dist/lib/translations.mjs"
    },
    "#types": {
      "source": "./src/types/index.ts",
      "types": "./dist/types/src/types/index.d.ts",
      "default": "./dist/lib/types/index.mjs"
    }
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/types/src/index.d.ts",
      "import": "./dist/lib/index.mjs"
    },
    "./assets/PLUGIN.mdl": "./PLUGIN.mdl",
    "./plugin": {
      "source": "./src/plugin.ts",
      "types": "./dist/types/src/plugin.d.ts",
      "import": "./dist/lib/plugin.mjs"
    },
    "./translations": {
      "source": "./src/translations.ts",
      "types": "./dist/types/src/translations.d.ts",
      "import": "./dist/lib/translations.mjs"
    }
  },
  "types": "dist/types/src/index.d.ts",
  "files": [
    "dist",
    "dx.config.ts",
    "src",
    "PLUGIN.mdl"
  ],
  "dependencies": {
    "@codemirror/state": "catalog:",
    "@dxos/app-framework": "workspace:*",
    "@dxos/app-toolkit": "workspace:*",
    "@dxos/compute": "workspace:*",
    "@dxos/echo": "workspace:*",
    "@dxos/effect": "workspace:*",
    "@dxos/keys": "workspace:*",
    "@dxos/log": "workspace:*",
    "@dxos/plugin-client": "workspace:*",
    "@dxos/plugin-deck": "workspace:*",
    "@dxos/plugin-graph": "workspace:*",
    "@dxos/plugin-markdown": "workspace:*",
    "@dxos/react-ui-attention": "workspace:*",
    "@dxos/react-ui-form": "workspace:*",
    "@dxos/ui-editor": "workspace:*",
    "@dxos/util": "workspace:*",
    "@effect-atom/atom-react": "catalog:",
    "hastscript": "catalog:",
    "highlight.js": "catalog:",
    "marked": "catalog:",
    "react-markdown": "catalog:",
    "react-resize-detector": "catalog:",
    "rehype-add-classes": "catalog:",
    "rehype-highlight": "catalog:",
    "remark-frontmatter": "catalog:",
    "remark-parse-frontmatter": "catalog:",
    "reveal.js": "catalog:"
  },
  "devDependencies": {
    "@dxos/plugin-testing": "workspace:*",
    "@dxos/random": "workspace:*",
    "@dxos/react-ui": "workspace:*",
    "@dxos/storybook-utils": "workspace:*",
    "@dxos/ui-theme": "workspace:*",
    "@effect-atom/atom-react": "catalog:",
    "@effect/platform": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/reveal.js": "catalog:",
    "effect": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "vite": "catalog:"
  },
  "peerDependencies": {
    "@dxos/react-ui": "workspace:^",
    "@dxos/ui-theme": "workspace:^",
    "@effect-atom/atom-react": "catalog:",
    "@effect/platform": "catalog:",
    "effect": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
