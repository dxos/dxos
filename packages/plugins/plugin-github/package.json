  },
  "license": "MIT",
  "author": "DXOS.org",
  "sideEffects": true,
  "type": "module",
  "imports": {
    "#plugin": "./src/GitHubPlugin.ts",
    "#capabilities": "./src/capabilities/index.ts",
    "#meta": "./src/meta.ts",
    "#operations": "./src/operations/index.ts"
  },
  "exports": {
