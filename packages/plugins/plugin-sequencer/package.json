{
  "name": "@dxos/plugin-sequencer",
  "version": "0.10.0",
  "private": true,
  "description": "Music sequencer plugin (Score / Track / Sequence / Note) with a canvas-based step grid.",
  "homepage": "https://dxos.org",
  "bugs": "https://github.com/dxos/dxos/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/dxos/dxos"
  },
  "license": "FSL-1.1-Apache-2.0",
  "author": "DXOS.org",
  "sideEffects": true,
  "type": "module",
  "imports": {
    "#capabilities": {
      "source": "./src/capabilities/index.ts",
      "types": "./dist/types/src/capabilities/index.d.ts",
      "default": "./dist/lib/capabilities/index.mjs"
    },
    "#components": {
      "source": "./src/components/index.ts",
      "types": "./dist/types/src/components/index.d.ts",
      "default": "./dist/lib/components/index.mjs"
    },
    "#containers": {
      "source": "./src/containers/index.ts",
      "types": "./dist/types/src/containers/index.d.ts",
      "default": "./dist/lib/containers/index.mjs"
    },
    "#meta": {
      "source": "./src/meta.ts",
      "types": "./dist/types/src/meta.d.ts",
      "default": "./dist/lib/meta.mjs"
    },
    "#plugin": {
      "source": {
        "workerd": "./src/SequencerPlugin.workerd.ts",
        "node": "./src/SequencerPlugin.node.ts",
        "default": "./src/SequencerPlugin.tsx"
      },
      "types": "./dist/types/src/SequencerPlugin.d.ts",
      "workerd": "./dist/lib/SequencerPlugin.workerd.mjs",
      "node": "./dist/lib/SequencerPlugin.node.mjs",
      "default": "./dist/lib/SequencerPlugin.mjs"
    },
    "#translations": {
      "source": "./src/translations.ts",
      "types": "./dist/types/src/translations.d.ts",
      "default": "./dist/lib/translations.mjs"
    },
    "#types": {
      "source": "./src/types/index.ts",
      "types": "./dist/types/src/types/index.d.ts",
      "default": "./dist/lib/types/index.mjs"
    }
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/types/src/index.d.ts",
      "import": "./dist/lib/index.mjs"
    },
    "./assets/PLUGIN.mdl": "./PLUGIN.mdl",
    "./plugin": {
      "source": "./src/plugin.ts",
      "types": "./dist/types/src/plugin.d.ts",
      "import": "./dist/lib/plugin.mjs"
    },
    "./types": {
      "source": "./src/types/index.ts",
      "types": "./dist/types/src/types/index.d.ts",
      "import": "./dist/lib/types.mjs"
    },
    "./translations": {
      "source": "./src/translations.ts",
      "types": "./dist/types/src/translations.d.ts",
      "import": "./dist/lib/translations.mjs"
    }
  },
  "types": "dist/types/src/index.d.ts",
  "files": [
    "dist",
    "dx.config.ts",
    "src",
    "PLUGIN.mdl"
  ],
  "dependencies": {
    "@dxos/app-framework": "workspace:*",
    "@dxos/app-toolkit": "workspace:*",
    "@dxos/compute": "workspace:*",
    "@dxos/echo": "workspace:*",
    "@dxos/echo-react": "workspace:*",
    "@dxos/invariant": "workspace:*",
    "@dxos/keys": "workspace:*",
    "@dxos/log": "workspace:*",
    "@dxos/plugin-space": "workspace:*",
    "@dxos/react-client": "workspace:*",
    "@dxos/react-ui-audio": "workspace:*",
    "@dxos/react-ui-canvas": "workspace:*",
    "@dxos/react-ui-list": "workspace:*",
    "@dxos/react-ui-menu": "workspace:*",
    "@dxos/util": "workspace:*",
    "@effect-atom/atom-react": "catalog:",
    "effect": "catalog:",
    "react-resize-detector": "catalog:",
    "tone": "catalog:"
  },
  "devDependencies": {
    "@dxos/random": "workspace:*",
    "@dxos/react-ui": "workspace:*",
    "@dxos/storybook-utils": "workspace:*",
    "@dxos/ui-theme": "workspace:*",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "vite": "catalog:"
  },
  "peerDependencies": {
    "@dxos/react-ui": "workspace:^",
    "@dxos/ui-theme": "workspace:^",
    "react": "catalog:",
    "react-dom": "catalog:"
  }
}
