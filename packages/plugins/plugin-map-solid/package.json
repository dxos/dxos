{
  "name": "@dxos/plugin-map-solid",
  "version": "0.10.0",
  "description": "Map plugin with solid web components",
  "homepage": "https://dxos.org",
  "bugs": "https://github.com/dxos/dxos/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/dxos/dxos"
  },
  "license": "FSL-1.1-Apache-2.0",
  "author": "DXOS.org",
  "sideEffects": true,
  "type": "module",
  "imports": {
    "#capabilities": {
      "source": "./src/capabilities/index.ts",
      "types": "./dist/types/src/capabilities/index.d.ts",
      "default": "./dist/lib/capabilities/index.mjs"
    },
    "#components": {
      "source": "./src/components/index.ts",
      "types": "./dist/types/src/components/index.d.ts",
      "default": "./dist/lib/components/index.mjs"
    },
    "#meta": {
      "source": "./src/meta.ts",
      "types": "./dist/types/src/meta.d.ts",
      "default": "./dist/lib/meta.mjs"
    },
    "#plugin": {
      "source": {
        "workerd": "./src/MapPlugin.workerd.ts",
        "node": "./src/MapPlugin.node.ts",
        "default": "./src/MapPlugin.tsx"
      },
      "types": "./dist/types/src/MapPlugin.d.ts",
      "workerd": "./dist/lib/MapPlugin.workerd.mjs",
      "node": "./dist/lib/MapPlugin.node.mjs",
      "default": "./dist/lib/MapPlugin.mjs"
    }
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/types/src/index.d.ts",
      "import": "./dist/lib/index.mjs"
    },
    "./assets/PLUGIN.mdl": "./PLUGIN.mdl",
    "./plugin": {
      "source": "./src/plugin.ts",
      "types": "./dist/types/src/plugin.d.ts",
      "import": "./dist/lib/plugin.mjs"
    }
  },
  "types": "dist/types/src/index.d.ts",
  "files": [
    "dist",
    "dx.config.ts",
    "src",
    "PLUGIN.mdl"
  ],
  "dependencies": {
    "@dxos/app-framework": "workspace:*",
    "@dxos/app-toolkit": "workspace:*",
    "@dxos/echo": "workspace:*",
    "@dxos/echo-solid": "workspace:*",
    "@dxos/keys": "workspace:*",
    "@dxos/operation": "workspace:*",
    "@dxos/plugin-map": "workspace:*",
    "@dxos/schema": "workspace:*",
    "@dxos/solid-ui-geo": "workspace:*",
    "@dxos/util": "workspace:*",
    "solid-element": "catalog:",
    "solid-js": "catalog:"
  },
  "devDependencies": {
    "effect": "catalog:"
  },
  "peerDependencies": {
    "effect": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
