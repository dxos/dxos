{
  "name": "@dxos/plugin-onboarding",
  "version": "0.10.0",
  "private": true,
  "description": "DXOS Composer onboarding plugin — identity setup, exemplar space, and auth flows.",
  "homepage": "https://dxos.org",
  "bugs": "https://github.com/dxos/dxos/issues",
  "repository": {
    "type": "git",
