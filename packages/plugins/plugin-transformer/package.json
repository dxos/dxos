{
  "name": "@dxos/plugin-transformer",
  "version": "0.10.0",
  "description": "Client transformer",
  "homepage": "https://dxos.org",
  "bugs": "https://github.com/dxos/dxos/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/dxos/dxos"
  },
  "license": "FSL-1.1-Apache-2.0",
  "author": "DXOS.org",
  "sideEffects": true,
  "type": "module",
  "imports": {
    "#components": {
      "source": "./src/components/index.ts",
      "types": "./dist/types/src/components/index.d.ts",
      "default": "./dist/lib/components/index.mjs"
    },
    "#hooks": {
      "source": "./src/hooks/index.ts",
      "types": "./dist/types/src/hooks/index.d.ts",
      "default": "./dist/lib/hooks/index.mjs"
    },
    "#meta": {
      "source": "./src/meta.ts",
      "types": "./dist/types/src/meta.d.ts",
      "default": "./dist/lib/meta.mjs"
    },
    "#plugin": {
      "source": "./src/TransformerPlugin.tsx",
      "types": "./dist/types/src/TransformerPlugin.d.ts",
      "default": "./dist/lib/TransformerPlugin.mjs"
    },
    "#translations": {
      "source": "./src/translations.ts",
      "types": "./dist/types/src/translations.d.ts",
      "default": "./dist/lib/translations.mjs"
    }
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/types/src/index.d.ts",
      "import": "./dist/lib/index.mjs"
    },
    "./assets/PLUGIN.mdl": "./PLUGIN.mdl",
    "./plugin": {
      "source": "./src/plugin.ts",
      "types": "./dist/types/src/plugin.d.ts",
      "import": "./dist/lib/plugin.mjs"
    },
    "./translations": {
      "source": "./src/translations.ts",
      "types": "./dist/types/src/translations.d.ts",
      "import": "./dist/lib/translations.mjs"
    }
  },
  "types": "dist/types/src/index.d.ts",
  "files": [
    "dist",
    "dx.config.ts",
    "src",
    "PLUGIN.mdl"
  ],
  "dependencies": {
    "@dxos/app-framework": "workspace:*",
    "@dxos/app-toolkit": "workspace:*",
    "@dxos/invariant": "workspace:*",
    "@dxos/keys": "workspace:*",
    "@dxos/log": "workspace:*",
    "@dxos/plugin-client": "workspace:*",
    "@dxos/util": "workspace:*",
    "@huggingface/transformers": "catalog:",
    "@xenova/transformers": "catalog:",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@dxos/plugin-testing": "workspace:*",
    "@dxos/random": "workspace:*",
    "@dxos/react-ui": "workspace:*",
    "@dxos/storybook-utils": "workspace:*",
    "@dxos/ui-theme": "workspace:*",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "vite": "catalog:"
  },
  "peerDependencies": {
    "@dxos/react-ui": "workspace:^",
    "@dxos/ui-theme": "workspace:^",
    "effect": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
