{
  "name": "@dxos/plugin-native-filesystem",
  "version": "0.11.0",
  "private": true,
  "description": "Composer plugin for native filesystem access via Tauri.",
  "homepage": "https://dxos.org",
  "bugs": "https://github.com/dxos/dxos/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/dxos/dxos"
  },
  "license": "FSL-1.1-Apache-2.0",
  "author": "DXOS.org",
  "sideEffects": true,
  "type": "module",
  "imports": {
    "#capabilities": {
      "source": "./src/capabilities/index.ts",
      "types": "./dist/types/src/capabilities/index.d.ts",
      "default": "./dist/lib/capabilities.mjs"
    },
    "#containers": {
      "source": "./src/containers/index.ts",
      "types": "./dist/types/src/containers/index.d.ts",
      "default": "./dist/lib/containers.mjs"
    },
    "#hooks": {
      "source": "./src/hooks/index.ts",
      "types": "./dist/types/src/hooks/index.d.ts",
      "default": "./dist/lib/hooks.mjs"
    },
    "#meta": {
      "source": "./src/meta.ts",
      "types": "./dist/types/src/meta.d.ts",
      "default": "./dist/lib/meta.mjs"
    },
    "#operations": {
      "source": "./src/operations/index.ts",
      "types": "./dist/types/src/operations/index.d.ts",
      "default": "./dist/lib/operations.mjs"
    },
    "#plugin": {
      "source": "./src/NativeFilesystemPlugin.tsx",
      "types": "./dist/types/src/NativeFilesystemPlugin.d.ts",
      "default": "./dist/lib/NativeFilesystemPlugin.mjs"
    },
    "#translations": {
      "source": "./src/translations.ts",
      "types": "./dist/types/src/translations.d.ts",
      "default": "./dist/lib/translations.mjs"
    },
    "#types": {
      "source": "./src/types/index.ts",
      "types": "./dist/types/src/types/index.d.ts",
      "default": "./dist/lib/types.mjs"
    }
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/types/src/index.d.ts",
      "import": "./dist/lib/index.mjs"
    },
    "./assets/PLUGIN.mdl": "./PLUGIN.mdl",
    "./plugin": {
      "source": "./src/plugin.ts",
      "types": "./dist/types/src/plugin.d.ts",
      "import": "./dist/lib/plugin.mjs"
    },
    "./translations": {
      "source": "./src/translations.ts",
      "types": "./dist/types/src/translations.d.ts",
      "import": "./dist/lib/translations.mjs"
    }
  },
  "types": "dist/types/src/index.d.ts",
  "files": [
    "dist",
    "dx.config.ts",
    "src",
    "PLUGIN.mdl"
  ],
  "dependencies": {
    "@dxos/app-framework": "workspace:*",
    "@dxos/app-toolkit": "workspace:*",
    "@dxos/async": "workspace:*",
    "@dxos/client": "workspace:*",
    "@dxos/compute": "workspace:*",
    "@dxos/echo": "workspace:*",
    "@dxos/echo-client": "workspace:*",
    "@dxos/effect": "workspace:*",
    "@dxos/invariant": "workspace:*",
    "@dxos/keys": "workspace:*",
    "@dxos/log": "workspace:*",
    "@dxos/plugin-client": "workspace:*",
    "@dxos/plugin-graph": "workspace:*",
    "@dxos/plugin-markdown": "workspace:*",
    "@dxos/plugin-space": "workspace:*",
    "@dxos/protocols": "workspace:*",
    "@dxos/react-client": "workspace:*",
    "@dxos/react-ui-form": "workspace:*",
    "@dxos/react-ui-pickers": "workspace:*",
    "@dxos/schema": "workspace:*",
    "@dxos/ui-editor": "workspace:*",
    "@dxos/util": "workspace:*",
    "@effect-atom/atom-react": "catalog:",
    "@tauri-apps/api": "catalog:",
    "@tauri-apps/plugin-dialog": "catalog:",
    "@tauri-apps/plugin-fs": "catalog:",
    "effect": "catalog:",
    "localforage": "catalog:"
  },
  "devDependencies": {
    "@dxos/app-graph": "workspace:*",
    "@dxos/plugin-testing": "workspace:*",
    "@dxos/react-ui": "workspace:*",
    "react": "catalog:",
    "vite": "catalog:"
  },
  "peerDependencies": {
    "@dxos/react-ui": "workspace:^",
    "effect": "catalog:",
    "react": "catalog:"
  }
}
