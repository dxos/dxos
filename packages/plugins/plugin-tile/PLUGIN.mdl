---
id: org.dxos.plugin.tile
name: TilePlugin
version: 0.1.0
---

A design tool plugin for creating tile patterns including tessellations.
Supports square, triangle, and hex grids with real-world dimensions,
grout lines, measurement overlays, and room fitting.

## Extensions

The following extension dialects are used in this document.
Each extension is defined in the Appendix or resolved via its URI.

| Term        | URI                            |
|-------------|--------------------------------|
| `type`      | `org.dxos.mdl.type@1.0`       |
| `feat`      | `org.dxos.mdl.feat@1.0`       |
| `test`      | `org.dxos.mdl.test@1.0`       |
| `component` | `org.dxos.mdl.component@1.0`  |
| `op`        | `org.dxos.mdl.op@1.0`         |
| `service`   | `org.dxos.mdl.service@1.0`    |

## Types

```mdl
type GridType
  literals: square | triangle | hex
```

```mdl
type RepeatMode
  literals: single | repeat
```

```mdl
type Coord
  desc: Axial coordinate key as "q,r" string.
  fields:
    q: number
    r: number
```

```mdl
type TilePattern
  desc: A tile pattern with grid configuration, physical dimensions, and cell color data.
  fields:
    name?: string                # e.g., "Kitchen backsplash"
    gridType: GridType           # tile geometry
    gridWidth: number            # columns (axial q range)
    gridHeight: number           # rows (axial r range)
    tileSize: number             # side length in mm
    groutWidth: number           # grout gap in mm (default 2)
    width?: number               # target surface width in mm
    height?: number              # target surface height in mm
    repeatMode: RepeatMode       # single canvas or repeating motif
    repeatWidth?: number         # motif width in cells (repeat mode)
    repeatHeight?: number        # motif height in cells (repeat mode)
    cells: Record<string, string>  # "q,r" → color hex string
```

## Components

```mdl
component TileArticle
  desc: Main article container for the tile pattern editor. Renders toolbar, canvas, and palette.
  props:
    pattern: TilePattern
  slots:
    toolbar?: ReactNode
  layout: |
    ┌─────────────────────────────────┐
    │ [toolbar]                       │
    ├─────────────────────────────────┤
    │                                 │
    │         TileCanvas              │
    │   (SVG with pan/zoom)           │
    │                                 │
    ├─────────────────────────────────┤
    │ TilePalette                     │
    └─────────────────────────────────┘
```

```mdl
component TileToolbar
  desc: Controls for grid type, tile size, grout width, repeat mode, room dimensions, and presets.
  props:
    pattern: TilePattern
  actions:
    setGridType(gridType: GridType)
    setTileSize(tileSize: number)
    setGroutWidth(groutWidth: number)
    setRepeatMode(mode: RepeatMode)
    setRoomDimensions(width: number, height: number)
    applyPreset(preset: string)
    exportPattern(format: string)
```

```mdl
component TileCanvas
  desc: SVG viewport with pan/zoom that renders the tile grid. Only renders tiles visible in the current viewport for performance.
  props:
    pattern: TilePattern
  state:
    viewBox: { x: number, y: number, width: number, height: number }
    hoveredCell?: Coord
  actions:
    pan(dx: number, dy: number)
    zoom(scale: number, center: { x: number, y: number })
    paintCell(coord: Coord, color: string)
    clearCell(coord: Coord)
  layout: |
    ┌─────────────────────────────┐
    │ <svg viewBox="...">         │
    │   TileGrid                  │
    │     TileCell × N (visible)  │
    │   GroutOverlay              │
    │   MeasurementOverlay        │
    │   RoomBoundary              │
    │ </svg>                      │
    └─────────────────────────────┘
```

```mdl
component TileGrid
  desc: Renders visible tile polygons within the current viewport.
  props:
    pattern: TilePattern
    viewBox: { x: number, y: number, width: number, height: number }
  emits:
    onCellClick(coord: Coord)
    onCellHover(coord: Coord)
```

```mdl
component TileCell
  desc: Individual SVG polygon representing one tile. Click to paint with active color.
  props:
    coord: Coord
    gridType: GridType
    tileSize: number
    color?: string
    hovered: boolean
  emits:
    onClick(coord: Coord)
    onHover(coord: Coord)
```

```mdl
component GroutOverlay
  desc: Renders grout lines between tiles as gaps in the SVG.
  props:
    groutWidth: number
    gridType: GridType
    tileSize: number
```

```mdl
component MeasurementOverlay
  desc: Dimension annotations showing real-world measurements on the pattern.
  props:
    pattern: TilePattern
```

```mdl
component RoomBoundary
  desc: Room outline overlay when surface dimensions are set.
  props:
    width?: number
    height?: number
    tileSize: number
    groutWidth: number
    gridType: GridType
```

```mdl
component TilePalette
  desc: Color picker for the active paint color.
  props:
    activeColor: string
  state:
    colors: string[]              # recent/saved colors
  actions:
    selectColor(color: string)
  emits:
    onColorChange(color: string)
```

```mdl
component TileCard
  desc: Thumbnail preview of a tile pattern for card surfaces.
  props:
    pattern: TilePattern
  layout: |
    ┌───────────┐
    │  static   │
    │  SVG      │
    │  preview  │
    ├───────────┤
    │ name      │
    │ grid info │
    └───────────┘
```

## Services

```mdl
service GridGeometry
  desc: Pure functions for coordinate conversion, hit-testing, and measurement. No React or ECHO dependencies.
  ops:
    axialToPixel(q: number, r: number, gridType: GridType, tileSize: number) → { x: number, y: number }
    pixelToAxial(x: number, y: number, gridType: GridType, tileSize: number) → Coord
    tileVertices(q: number, r: number, gridType: GridType, tileSize: number) → string
    visibleRange(viewBox: object, gridType: GridType, tileSize: number) → { qMin: number, qMax: number, rMin: number, rMax: number }
    gridToPhysical(tileSize: number, groutWidth: number, gridWidth: number, gridHeight: number) → { widthMm: number, heightMm: number }
    fitToRoom(width: number, height: number, tileSize: number, groutWidth: number, gridType: GridType) → { gridWidth: number, gridHeight: number }
```

```mdl
service PresetLibrary
  desc: Built-in tile pattern presets that fill cells with known tessellation patterns.
  ops:
    list() → Preset[]
    apply(preset: string, gridType: GridType, gridWidth: number, gridHeight: number, colors: string[]) → Record<string, string>
  note: |
    Initial presets: checkerboard, herringbone, honeycomb, pinwheel, basketweave, diamond.
    Each preset generates a cells map for the given grid dimensions and color palette.
```

## Operations

```mdl
op create
  desc: Creates a new TilePattern with the given grid configuration.
  input:
    name?: string
    gridType: GridType
    gridWidth: number
    gridHeight: number
    tileSize: number
    groutWidth?: number
  output: TilePattern
  effects: [echo:write]
  requires: [Database]
```

```mdl
op applyPreset
  desc: Fills a pattern's cells with a named preset tessellation.
  input:
    pattern: TilePattern
    preset: string
    colors: string[]
  output: TilePattern
  effects: [echo:write]
  requires: [PresetLibrary]
```

```mdl
op export
  desc: Generates an SVG or PNG export of the tile pattern.
  input:
    pattern: TilePattern
    format: svg | png
  output: Blob
  requires: [GridGeometry]
```

## Features

```mdl
feat F-1: Grid Display

  req F-1.1: Pattern renders as an SVG with correct tile geometry for the selected grid type.
  req F-1.2: Square tiles render as axis-aligned squares.
  req F-1.3: Hex tiles render as regular hexagons in flat-top orientation.
  req F-1.4: Triangle tiles render as alternating up/down equilateral triangles.
  req F-1.5: Only tiles visible in the current viewport are rendered (virtualization).
```

```mdl
feat F-2: Cell Painting

  req F-2.1:
    when: user clicks an empty cell
    then: cell painted with active color; entry added to cells map

  req F-2.2:
    when: user clicks a painted cell with the same color
    then: cell cleared; entry removed from cells map

  req F-2.3:
    when: user clicks a painted cell with a different color
    then: cell repainted with new color

  req F-2.4: Active color is selected via the TilePalette component.
```

```mdl
feat F-3: Pan and Zoom

  req F-3.1: User can pan the canvas by dragging.
  req F-3.2: User can zoom with scroll wheel or pinch gesture.
  req F-3.3: SVG viewBox updates to reflect current viewport.
  req F-3.4: Tile rendering updates to show only visible tiles after pan/zoom.
```

```mdl
feat F-4: Grout Lines

  req F-4.1: Grout rendered as gaps between tile polygons.
  req F-4.2: Grout width is configurable via the toolbar.
  req F-4.3: Grout width affects physical measurement calculations.
```

```mdl
feat F-5: Room Fitting

  req F-5.1: User can set target surface dimensions (width, height) in mm.
  req F-5.2:
    when: room dimensions are set
    then: grid auto-sizes to fill the surface, accounting for tile size and grout

  req F-5.3: Room boundary displayed as an overlay on the canvas.
  req F-5.4: Measurement overlay shows real-world dimensions.
```

```mdl
feat F-6: Repeat Mode

  req F-6.1: User can toggle between single-canvas and repeat-motif mode.
  req F-6.2:
    when: repeat mode is active
    then: user defines a small motif area (repeatWidth × repeatHeight)

  req F-6.3:
    when: repeat mode is active
    then: motif tiles across the full grid; preview shows the repeated pattern

  req F-6.4: Cell edits in repeat mode only modify the motif; tiled copies update automatically.
```

```mdl
feat F-7: Presets

  req F-7.1: User can apply a preset pattern from the toolbar.
  req F-7.2: Presets fill the cells map with a known tessellation pattern and colors.
  req F-7.3: Initial presets: checkerboard, herringbone, honeycomb, pinwheel, basketweave, diamond.
  req F-7.4: Applying a preset replaces existing cell data.
```

```mdl
feat F-8: Export

  req F-8.1: User can export the pattern as SVG.
  req F-8.2: User can export the pattern as PNG.
  req F-8.3: Export includes grout lines and respects physical dimensions.
```

## Acceptance

```mdl
test T-1: Create square grid pattern
  given: user creates a new TilePattern
  when: gridType is square, gridWidth is 10, gridHeight is 10, tileSize is 50
  then:
    - pattern is created with empty cells map
    - 10×10 grid of square tiles displayed in SVG
```

```mdl
test T-2: Paint and clear cells
  given: a square grid pattern is displayed
  when: user clicks cell (3,4) with active color "#3b82f6"
  then:
    - cells["3,4"] === "#3b82f6"
    - cell renders with blue fill
  when: user clicks cell (3,4) again with same color
  then:
    - cells["3,4"] is removed
    - cell renders as empty
```

```mdl
test T-3: Hex grid rendering
  given: a TilePattern with gridType hex
  then:
    - tiles render as regular hexagons
    - axial coordinates map correctly to hex positions
```

```mdl
test T-4: Triangle grid rendering
  given: a TilePattern with gridType triangle
  then:
    - tiles render as alternating up/down triangles
    - adjacent triangles share edges correctly
```

```mdl
test T-5: Grout spacing
  given: a pattern with tileSize 100 and groutWidth 5
  then:
    - visible gap of 5mm (scaled) between adjacent tiles
    - physical measurements account for grout
```

```mdl
test T-6: Room fitting
  given: a pattern with tileSize 100, groutWidth 2
  when: user sets width 2000, height 1500
  then:
    - gridWidth and gridHeight auto-calculated to fill room
    - room boundary overlay visible on canvas
    - measurement overlay shows 2000mm × 1500mm
```

```mdl
test T-7: Repeat mode
  given: a pattern in repeat mode with repeatWidth 3, repeatHeight 3
  when: user paints cells in the 3×3 motif
  then:
    - motif tiles across the full grid
    - all tiled copies reflect the motif edits
```

```mdl
test T-8: Apply preset
  given: a 10×10 square grid pattern
  when: user applies checkerboard preset with colors ["#000", "#fff"]
  then:
    - alternating cells filled with black and white
    - cells map contains entries for all 100 cells
```

```mdl
test T-9: Viewport virtualization
  given: a large 100×100 grid pattern
  when: user is viewing a section of the grid
  then:
    - only tiles within the visible viewport are rendered as SVG elements
    - panning reveals new tiles and removes off-screen tiles
```

```mdl
test T-10: SVG export
  given: a painted tile pattern
  when: user exports as SVG
  then:
    - valid SVG file generated
    - includes all tiles with correct colors
    - includes grout lines
    - dimensions match physical measurements
```

---

## Appendix: Extension Definitions

Extension block types used in this document are defined below using
the core `ext` primitive — the only construct the base language provides.

```mdl
ext type
  uri: dxos.spec/ext/type@1.0
  desc: A named data structure with typed fields and optional literals.
  fields:
    desc?: Prose
    fields?: FieldMap        # name[?]: TypeExpr  (# inline comment)
    literals?: UnionList     # a | b | c
    extends?: TypeRef[]
```

```mdl
ext feat
  uri: dxos.spec/ext/feat@1.0
  desc: A named feature grouping one or more requirements.
  fields:
    desc?: Prose
    req: RequirementList
  nesting: self              # feat blocks may contain feat blocks
```

```mdl
ext test
  uri: dxos.spec/ext/test@1.0
  desc: An acceptance scenario expressed as given / when / then steps.
  fields:
    given?: Step | Step[]
    when?: Step | Step[]
    then: Step | Step[]
    tags?: TagList
```

```mdl
ext component
  uri: org.dxos.mdl.component@1.0
  desc: A UI component with props, internal state, slots, actions, and events.
  fields:
    desc?: Prose
    props?: FieldMap            # external inputs (immutable inside component)
    state?: FieldMap            # internal reactive state
    slots?: FieldMap            # named ReactNode injection points
    actions?: ActionMap         # methods the component exposes or handles
    emits?: EventMap            # events the component raises to its parent
    layout?: CodeBlock          # ASCII sketch of visual structure (non-normative)
```

```mdl
ext op
  uri: org.dxos.mdl.op@1.0
  desc: |
    A named operation with typed inputs, outputs, and declared errors.
    Pure ops have no effects or requires. Effectful ops declare both.
  fields:
    desc?: Prose
    input?: FieldMap            # named input parameters
    output?: TypeExpr           # return type
    errors?: ErrorMap           # name: Prose  (when this error occurs)
    effects?: EffectList        # echo:read | echo:write | http | fs | ...
    requires?: ServiceList      # injected service dependencies
    note?: Prose                # implementation guidance (non-normative)
```

```mdl
ext service
  uri: org.dxos.mdl.service@1.0
  desc: An external or system-level dependency providing named operations.
  fields:
    desc?: Prose
    loading?: eager | lazy
    ops?: OpMap                 # name(params) → ReturnType
    errors?: ErrorMap
    note?: Prose
```
