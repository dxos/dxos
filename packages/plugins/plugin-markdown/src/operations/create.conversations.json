ype":"object","required":["name","content"],"properties":{"name":{"type":"string"},"content":{"type":"string"}},"additionalProperties":false}},{"name":"open","description":"Opens and reads the contents of a new markdown document.","inputSchema":{"type":"object","required":["doc"],"properties":{"doc":{"type":"string","description":"The ID of the referenced object. Formats accepted:\n- DXN (dxn:echo:@:01KG7R1ZXWFMWQ4DA1Q6TN1DG4). DXNs can be prepended with an @ symbol for compatibility with in-text references.\n- space ID, object ID tuple (spaceID:objectID)\n- Only object ID that is assumed to be in the current space (01KG7R1ZXWFMWQ4DA1Q6TN1DG4)","examples":["dxn:echo:@:01KG7R1ZXWFMWQ4DA1Q6TN1DG4","@dxn:echo:@:01KG7R1ZXWFMWQ4DA1Q6TN1DG4","BM3FSHFOMJCHCG5QW7JTVKGYABD2GAA7G:01KG7R1ZXWFMWQ4DA1Q6TN1DG4","01KG7R1ZXWFMWQ4DA1Q6TN1DG4"]}},"additionalProperties":false}},{"name":"update","description":"Applies a set of edits to the markdown document.","inputSchema":{"type":"object","required":["doc","edits"],"properties":{"doc":{"type":"string","description":"The ID of the referenced object. Formats accepted:\n- DXN (dxn:echo:@:01KG7R1ZXWFMWQ4DA1Q6TN1DG4). DXNs can be prepended with an @ symbol for compatibility with in-text references.\n- space ID, object ID tuple (spaceID:objectID)\n- Only object ID that is assumed to be in the current space (01KG7R1ZXWFMWQ4DA1Q6TN1DG4)","examples":["dxn:echo:@:01KG7R1ZXWFMWQ4DA1Q6TN1DG4","@dxn:echo:@:01KG7R1ZXWFMWQ4DA1Q6TN1DG4","BM3FSHFOMJCHCG5QW7JTVKGYABD2GAA7G:01KG7R1ZXWFMWQ4DA1Q6TN1DG4","01KG7R1ZXWFMWQ4DA1Q6TN1DG4"]},"edits":{"type":"array","items":{"type":"object","required":["oldString","newString"],"properties":{"oldString":{"type":"string","description":"The text to find in the document."},"newString":{"type":"string","description":"The text to replace it with."},"replaceAll":{"type":"boolean","description":"If true, replaces all occurrences. Defaults to false (first occurrence only)."}},"additionalProperties":false},"description":"The edits to apply to the document. Each edit finds oldString and replaces it with newString."}},"additionalProperties":false}}]},"prompt":{"content":[{"role":"system","content":"## Blueprints Definitions\n\n<blueprint>\n  You can create, read and update markdown documents.\n  When asked to edit or update documents return updates as a set of compact diff string pairs.\n  For each diff, respond with the smallest possible matching span.\n  \n  Example:\n  ```diff\n  - \"There is a tyop in this sentence.\"\n  + \"There is a typo in this sentence.\"\n  - \"This id good.\"\n  + \"This sentence is really good.\"\n  ```\n</blueprint>","options":{}},{"role":"user","content":"Create a document with a cookie recipe.","options":{}},{"role":"assistant","content":[{"type":"reasoning","text":"The user wants me to create a document with a cookie recipe. Let me create a nice markdown document with a classic cookie recipe.","options":{}},{"type":"tool-call","id":"toolu_01HaGMocBtHECA3FzJnRWCuj","name":"create","params":{"name":"Classic Chocolate Chip Cookies","content":"# Classic Chocolate Chip Cookies\n\nA timeless recipe for soft, chewy chocolate chip cookies that are golden on the edges and gooey in the center.\n\n## Ingredients\n\n- 2 ¼ cups all-purpose flour\n- 1 tsp baking soda\n- 1 tsp salt\n- 1 cup (2 sticks) unsalted butter, softened\n- ¾ cup granulated sugar\n- ¾ cup packed brown sugar\n- 2 large eggs\n- 2 tsp vanilla extract\n- 2 cups semi-sweet chocolate chips\n\n## Instructions\n\n1. **Preheat** the oven to 375°F (190°C). Line baking sheets with parchment paper.\n2. **Combine dry ingredients:** Whisk together the flour, baking soda, and salt in a medium bowl. Set aside.\n3. **Cream the butter and sugars:** In a large bowl, beat the softened butter, granulated sugar, and brown sugar until light and fluffy (about 2–3 minutes).\n4. **Add eggs and vanilla:** Beat in the eggs one at a time, then mix in the vanilla extract.\n5. **Mix in dry ingredients:** Gradually add the flour mixture to the wet ingredients, mixing on low speed until just combined.\n6. **Fold in chocolate chips:** Stir in the chocolate chips with a spatula or wooden spoon.\n7. **Scoop the dough:** Drop rounded tablespoons of dough onto the prepared baking sheets, spacing them about 2 inches apart.\n8. **Bake:** Bake for 9–11 minutes, or until the edges are golden brown but the centers still look slightly underdone.\n9. **Cool:** Let the cookies cool on the baking sheet for 5 minutes, then transfer to a wire rack to cool completely.\n\n## Tips\n\n- **Chill the dough** for at least 30 minutes (or up to 24 hours) for thicker, chewier cookies.\n- **Don't overmix** the dough once the flour is added — this keeps the cookies tender.\n- **Use a cookie scoop** for evenly sized cookies that bake uniformly.\n\n## Yield\n\nMakes approximately **48 cookies**.\n\nEnjoy! 🍪"},"providerExecuted":false,"options":{}}],"options":{}},{"role":"tool","content":[{"type":"tool-result","id":"toolu_01HaGMocBtHECA3FzJnRWCuj","name":"create","isFailure":false,"result":{"_id":"Exit","_tag":"Success","value":{"id":"dxn:echo:BDJXMULPW5FB55UZ7KP5HLDHVTXUTHE2U:01JGFJJZ00G0WKQSJGMAKCNTHJ"}},"providerExecuted":false,"options":{}}],"options":{"anthropic":{"cacheControl":{"ttl":"5m","type":"ephemeral"}}}}]},"response":[{"type":"response-metadata","id":"msg_01DVyo2JvJhmnn32KKagR7uE","modelId":"claude-opus-4-6","timestamp":"2026-05-01T08:13:41.976Z","metadata":{}},{"type":"text-start","id":"0","metadata":{}},{"type":"text-delta","id":"0","delta":"Your","metadata":{}},{"type":"text-delta","id":"0","delta":" cookie recipe document has been created! 🍪 It includes:\n\n- **Title","metadata":{}},{"type":"text-delta","id":"0","delta":":** Classic Chocolate Chip Cookies\n- **Ingredients** — a full list with","metadata":{}},{"type":"text-delta","id":"0","delta":" measurements for butter, sugars, flour, eggs, vanilla, and chocolate chips\n- **Step-by-step instructions** —","metadata":{}},{"type":"text-delta","id":"0","delta":" from preheating the oven to cooling the cookies\n- **Helpful tips** — like chilling the dough for thicker cookies and avoiding overmixing\n- **Yield** — approximately 48 cookies","metadata":{}},{"type":"text-delta","id":"0","delta":"\n\nLet me know if you'd like to make any changes or additions!","metadata":{}},{"type":"text-end","id":"0","metadata":{}},{"type":"finish","reason":"stop","usage":{"inputTokens":2253,"outputTokens":131,"totalTokens":2384},"metadata":{"anthropic":{"usage":{"cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"cache_creation_input_tokens":0,"cache_read_input_tokens":0,"input_tokens":2253,"output_tokens":1,"server_tool_use":null,"service_tier":"standard"}}}}]}]}