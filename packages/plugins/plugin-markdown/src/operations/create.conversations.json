JCHCG5QW7JTVKGYABD2GAA7G:01KG7R1ZXWFMWQ4DA1Q6TN1DG4","01KG7R1ZXWFMWQ4DA1Q6TN1DG4","dxn:org.dxos.type.calendar:0.1.0","@dxn:org.dxos.type.calendar:0.1.0"]}},"additionalProperties":false}},{"name":"update","description":"Applies a set of edits to the markdown document.","inputSchema":{"type":"object","required":["doc","edits"],"properties":{"doc":{"type":"string","description":"The URI of the referenced object. Protocols accepted:\n- echo://01KG7R1ZXWFMWQ4DA1Q6TN1DG4. \n- space ID, object ID tuple (spaceID:objectID)\n- Only object ID that is assumed to be in the current space (01KG7R1ZXWFMWQ4DA1Q6TN1DG4)\n- dxn:org.dxos.type.calendar:0.1.0 -- named entity from the registry. Absoutely make sure it actually exists in the registry.\n\nURIs can be prepended with an @ symbol for compatibility with in-text references.","examples":["echo://01KG7R1ZXWFMWQ4DA1Q6TN1DG4","@echo://01KG7R1ZXWFMWQ4DA1Q6TN1DG4","BM3FSHFOMJCHCG5QW7JTVKGYABD2GAA7G:01KG7R1ZXWFMWQ4DA1Q6TN1DG4","01KG7R1ZXWFMWQ4DA1Q6TN1DG4","dxn:org.dxos.type.calendar:0.1.0","@dxn:org.dxos.type.calendar:0.1.0"]},"edits":{"type":"array","items":{"type":"object","required":["newString"],"properties":{"oldString":{"type":"string","description":"The text to find in the document. Set to undefined to append the newString to the end of the document."},"newString":{"type":"string","description":"The text to replace it with."},"replaceAll":{"type":"boolean","description":"If true, replaces all occurrences. Defaults to false (first occurrence only)."}},"additionalProperties":false},"description":"The edits to apply to the document. Each edit finds oldString and replaces it with newString; omit oldString to append newString to the end."}},"additionalProperties":false}}]},"prompt":{"content":[{"role":"system","content":"## Skills Definitions\n\n<skill>\n  You can create, read and update markdown documents.\n  When asked to edit or update documents return updates as a set of compact diff string pairs.\n  For each diff, respond with the smallest possible matching span.\n  \n  Example:\n  ```diff\n  - \"There is a tyop in this sentence.\"\n  + \"There is a typo in this sentence.\"\n  - \"This id good.\"\n  + \"This sentence is really good.\"\n  ```\n</skill>","options":{}},{"role":"user","content":"Create a document with a cookie recipe.","options":{}},{"role":"assistant","content":[{"type":"reasoning","text":"The user wants me to create a document with a cookie recipe. Let me create a nice markdown document with a classic cookie recipe.","options":{}},{"type":"tool-call","id":"toolu_01RqhRALCgRpbyhMFC9Vh4HV","name":"create","params":{"name":"Classic Chocolate Chip Cookies","content":"# Classic Chocolate Chip Cookies\n\nA timeless recipe for soft, chewy chocolate chip cookies that are crispy on the edges and gooey in the center.\n\n## Ingredients\n\n- 2 ¼ cups all-purpose flour\n- 1 tsp baking soda\n- 1 tsp salt\n- 1 cup (2 sticks) unsalted butter, softened\n- ¾ cup granulated sugar\n- ¾ cup packed brown sugar\n- 2 large eggs\n- 2 tsp vanilla extract\n- 2 cups semi-sweet chocolate chips\n\n## Instructions\n\n1. **Preheat** your oven to 375°F (190°C). Line baking sheets with parchment paper.\n2. **Mix dry ingredients:** In a medium bowl, whisk together the flour, baking soda, and salt. Set aside.\n3. **Cream butter and sugars:** In a large bowl, beat the softened butter, granulated sugar, and brown sugar together until light and fluffy (about 2–3 minutes).\n4. **Add eggs and vanilla:** Beat in the eggs one at a time, then mix in the vanilla extract.\n5. **Combine:** Gradually add the dry ingredients to the wet ingredients, mixing on low speed until just combined. Do not overmix.\n6. **Fold in chocolate chips:** Stir in the chocolate chips with a spatula or wooden spoon.\n7. **Scoop and bake:** Drop rounded tablespoons of dough onto the prepared baking sheets, spacing them about 2 inches apart. Bake for 9–11 minutes, or until the edges are golden brown but the centers still look slightly underdone.\n8. **Cool:** Let the cookies cool on the baking sheet for 5 minutes, then transfer to a wire rack to cool completely.\n\n## Tips\n\n- **Chill the dough** for at least 30 minutes (or overnight) for thicker, chewier cookies.\n- **Use room-temperature eggs** for a smoother batter.\n- **Don't overbake!** The cookies will continue to firm up as they cool.\n- Store in an airtight container for up to 5 days.\n\n## Yield\n\nMakes approximately **48 cookies**.\n\nEnjoy! 🍪"},"providerExecuted":false,"options":{}}],"options":{}},{"role":"tool","content":[{"type":"tool-result","id":"toolu_01RqhRALCgRpbyhMFC9Vh4HV","name":"create","isFailure":false,"result":{"id":"echo://BDJXMULPW5FB55UZ7KP5HLDHVTXUTHE2U/01JGFJJZ00G0WKQSJGMAKCNTJ8"},"providerExecuted":false,"options":{}}],"options":{"anthropic":{"cacheControl":{"ttl":"5m","type":"ephemeral"}}}}]},"response":[{"type":"response-metadata","id":"msg_01BJ2iN14GYRUo9bQrEmdPSE","modelId":"claude-opus-4-6","timestamp":"2026-06-28T07:17:09.941Z","metadata":{}},{"type":"text-start","id":"0","metadata":{}},{"type":"text-delta","id":"0","delta":"Your","metadata":{}},{"type":"text-delta","id":"0","delta":" cookie recipe document has been created! 🍪 It includes a full recipe for","metadata":{}},{"type":"text-delta","id":"0","delta":" **Classic Chocolate Chip Cookies** with:\n\n- **Ingredients** — butter, sugars, flour, eggs, vanilla, and chocolate chips","metadata":{}},{"type":"text-delta","id":"0","delta":"\n- **Step-by-step instructions** — from preheating the oven to cooling the cookies\n- **Helpful tips** — like chilling the dough for","metadata":{}},{"type":"text-delta","id":"0","delta":" chewier cookies and avoiding overbaking\n- **Yield** — approximately 48 cookies\n\nLet me know if you'd like to make any changes","metadata":{}},{"type":"text-delta","id":"0","delta":" or additions!","metadata":{}},{"type":"text-end","id":"0","metadata":{}},{"type":"finish","reason":"stop","usage":{"inputTokens":2385,"outputTokens":127,"totalTokens":25