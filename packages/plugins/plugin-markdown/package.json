{
  "name": "@dxos/plugin-markdown",
  "version": "0.10.0",
  "description": "DXOS Surface plugin for interacting with Markdown",
  "homepage": "https://dxos.org",
  "bugs": "https://github.com/dxos/dxos/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/dxos/dxos"
  },
  "license": "FSL-1.1-Apache-2.0",
  "author": "DXOS.org",
  "sideEffects": true,
  "type": "module",
  "imports": {
    "#skills": {
      "source": "./src/skills/index.ts",
      "types": "./dist/types/src/skills/index.d.ts",
      "default": "./dist/lib/skills.mjs"
    },
    "#capabilities": {
      "source": {
        "node": "./src/capabilities/node.ts",
        "default": "./src/capabilities/index.ts"
      },
      "types": "./dist/types/src/capabilities/index.d.ts",
      "node": "./dist/lib/capabilities/node.mjs",
      "default": "./dist/lib/capabilities.mjs"
    },
    "#components": {
      "source": "./src/components/index.ts",
      "types": "./dist/types/src/components/index.d.ts",
      "default": "./dist/lib/components.mjs"
    },
    "#containers": {
      "source": "./src/containers/index.ts",
      "types": "./dist/types/src/containers/index.d.ts",
      "default": "./dist/lib/containers.mjs"
    },
    "#hooks": {
      "source": "./src/hooks/index.ts",
      "types": "./dist/types/src/hooks/index.d.ts",
      "default": "./dist/lib/hooks.mjs"
    },
    "#meta": {
      "source": "./src/meta.ts",
      "types": "./dist/types/src/meta.d.ts",
      "default": "./dist/lib/meta.mjs"
    },
    "#operations": {
      "source": "./src/operations/index.ts",
      "types": "./dist/types/src/operations/index.d.ts",
      "default": "./dist/lib/operations.mjs"
    },
    "#plugin": {
      "source": {
        "workerd": "./src/MarkdownPlugin.workerd.ts",
        "node": "./src/MarkdownPlugin.node.ts",
        "default": "./src/MarkdownPlugin.tsx"
      },
      "types": "./dist/types/src/MarkdownPlugin.d.ts",
      "workerd": "./dist/lib/MarkdownPlugin.workerd.mjs",
      "node": "./dist/lib/MarkdownPlugin.node.mjs",
      "default": "./dist/lib/MarkdownPlugin.mjs"
    },
    "#testing": {
      "source": "./src/testing.ts",
      "types": "./dist/types/src/testing.d.ts",
      "default": "./dist/lib/testing.mjs"
    },
    "#translations": {
      "source": "./src/translations.ts",
      "types": "./dist/types/src/translations.d.ts",
      "default": "./dist/lib/translations.mjs"
    },
    "#types": {
      "source": "./src/types/index.ts",
      "types": "./dist/types/src/types/index.d.ts",
      "default": "./dist/lib/types.mjs"
    }
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/types/src/index.d.ts",
      "import": "./dist/lib/index.mjs"
    },
    "./skills": {
      "source": "./src/skills/index.ts",
      "types": "./dist/types/src/skills/index.d.ts",
      "import": "./dist/lib/skills.mjs"
    },
    "./plugin": {
      "source": "./src/plugin.ts",
      "types": "./dist/types/src/plugin.d.ts",
      "import": "./dist/lib/plugin.mjs"
    },
    "./testing": {
      "source": "./src/testing.ts",
      "types": "./dist/types/src/testing.d.ts",
      "import": "./dist/lib/testing.mjs"
    },
    "./translations": {
      "source": "./src/translations.ts",
      "types": "./dist/types/src/translations.d.ts",
      "import": "./dist/lib/translations.mjs"
    },
    "./types": {
      "source": "./src/types/index.ts",
      "types": "./dist/types/src/types/index.d.ts",
      "import": "./dist/lib/types.mjs"
    }
  },
  "types": "dist/types/src/index.d.ts",
  "files": [
    "dist",
    "dx.config.ts",
    "src"
  ],
  "dependencies": {
    "@automerge/automerge": "catalog:",
    "@codemirror/state": "catalog:",
    "@codemirror/view": "catalog:",
    "@dxos/ai": "workspace:*",
    "@dxos/app-framework": "workspace:*",
    "@dxos/app-toolkit": "workspace:*",
    "@dxos/assistant": "workspace:*",
    "@dxos/async": "workspace:*",
    "@dxos/client": "workspace:*",
    "@dxos/client-protocol": "workspace:*",
    "@dxos/compute": "workspace:*",
    "@dxos/echo": "workspace:*",
    "@dxos/echo-client": "workspace:*",
    "@dxos/echo-doc": "workspace:*",
    "@dxos/effect": "workspace:*",
    "@dxos/invariant": "workspace:*",
    "@dxos/keys": "workspace:*",
    "@dxos/log": "workspace:*",
    "@dxos/plugin-attention": "workspace:*",
    "@dxos/plugin-client": "workspace:*",
    "@dxos/plugin-graph": "workspace:*",
    "@dxos/plugin-preview": "workspace:*",
    "@dxos/plugin-sketch": "workspace:*",
    "@dxos/plugin-space": "workspace:*",
    "@dxos/react-client": "workspace:*",
    "@dxos/react-ui-attention": "workspace:*",
    "@dxos/react-ui-dnd": "workspace:*",
    "@dxos/react-ui-editor": "workspace:*",
    "@dxos/react-ui-form": "workspace:*",
    "@dxos/react-ui-menu": "workspace:*",
    "@dxos/react-ui-mosaic": "workspace:*",
    "@dxos/schema": "workspace:*",
    "@dxos/types": "workspace:*",
    "@dxos/ui": "workspace:*",
    "@dxos/ui-editor": "workspace:*",
    "@dxos/util": "workspace:*",
    "@effect-atom/atom-react": "catalog:",
    "@effect/ai": "catalog:",
    "@effect/experimental": "catalog:",
    "@radix-ui/react-context": "catalog:",
    "react-dropzone": "catalog:"
  },
  "devDependencies": {
    "@dxos/agent-runtime": "workspace:*",
    "@dxos/debug": "workspace:*",
    "@dxos/plugin-testing": "workspace:*",
    "@dxos/plugin-theme": "workspace:*",
    "@dxos/random": "workspace:*",
    "@dxos/react-ui": "workspace:*",
    "@dxos/storybook-utils": "workspace:*",
    "@dxos/ui-theme": "workspace:*",
    "@effect-atom/atom-react": "catalog:",
    "@effect/platform": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "effect": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "vite": "catalog:"
  },
  "peerDependencies": {
    "@dxos/react-ui": "workspace:^",
    "@dxos/ui-theme": "workspace:^",
    "@effect-atom/atom-react": "catalog:",
    "@effect/platform": "catalog:",
    "effect": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
