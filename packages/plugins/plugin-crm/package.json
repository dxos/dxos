{
  "name": "@dxos/plugin-crm",
  "version": "0.8.3",
  "private": true,
  "description": "CRM plugin for Composer. Provides a blueprint for researching people and organizations and producing structured Profile documents.",
  "homepage": "https://dxos.org",
  "bugs": "https://github.com/dxos/dxos/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/dxos/dxos"
  },
  "license": "MIT",
  "author": "DXOS.org",
  "sideEffects": true,
  "type": "module",
  "imports": {
    "#blueprints": "./src/blueprints/index.ts",
    "#capabilities": "./src/capabilities/index.ts",
    "#meta": "./src/meta.ts",
    "#operations": "./src/operations/index.ts",
    "#sources": "./src/sources/index.ts",
    "#testing": "./src/testing/index.ts",
    "#types": "./src/types/index.ts",
    "#util": "./src/util/index.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/types/src/index.d.ts",
      "import": "./dist/lib/index.mjs"
    },
    "./blueprints": {
      "types": "./dist/types/src/blueprints/index.d.ts",
      "import": "./dist/lib/blueprints.mjs"
    },
    "./operations": {
      "types": "./dist/types/src/operations/index.d.ts",
      "import": "./dist/lib/operations.mjs"
    },
    "./sources": {
      "types": "./dist/types/src/sources/index.d.ts",
      "import": "./dist/lib/sources.mjs"
    },
    "./testing": {
      "types": "./dist/types/src/testing/index.d.ts",
      "import": "./dist/lib/testing.mjs"
    },
    "./types": {
      "types": "./dist/types/src/types/index.d.ts",
      "import": "./dist/lib/types.mjs"
    }
  },
  "types": "dist/types/src/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@dxos/app-framework": "workspace:*",
    "@dxos/app-toolkit": "workspace:*",
    "@dxos/assistant-toolkit": "workspace:*",
    "@dxos/compute": "workspace:*",
    "@dxos/echo": "workspace:*",
    "@dxos/functions": "workspace:*",
    "@dxos/invariant": "workspace:*",
    "@dxos/log": "workspace:*",
    "@dxos/operation": "workspace:*",
    "@dxos/plugin-markdown": "workspace:*",
    "@dxos/schema": "workspace:*",
    "@dxos/types": "workspace:*",
    "@dxos/util": "workspace:*",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@dxos/assistant": "workspace:*",
    "@dxos/effect": "workspace:*",
    "@dxos/functions-runtime": "workspace:*",
    "@dxos/keys": "workspace:*",
    "@effect/vitest": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
