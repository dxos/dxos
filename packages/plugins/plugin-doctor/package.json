{
  "name": "@dxos/plugin-doctor",
  "version": "0.8.3",
  "private": true,
  "description": "Self-introspection blueprint: query the browser tab's own logs.",
  "homepage": "https://dxos.org",
  "bugs": "https://github.com/dxos/dxos/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/dxos/dxos"
  },
  "license": "MIT",
  "author": "DXOS.org",
  "sideEffects": true,
  "type": "module",
  "imports": {
    "#blueprints": "./src/blueprints/index.ts",
    "#capabilities": "./src/capabilities/index.ts",
    "#meta": "./src/meta.ts",
    "#operations": "./src/operations/index.ts",
    "#translations": "./src/translations.ts"
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/types/src/index.d.ts",
      "browser": "./dist/lib/browser/index.mjs",
      "node": "./dist/lib/node-esm/index.mjs"
    },
    "./blueprints": {
      "source": "./src/blueprints/index.ts",
      "types": "./dist/types/src/blueprints/index.d.ts",
      "browser": "./dist/lib/browser/blueprints/index.mjs",
      "node": "./dist/lib/node-esm/blueprints/index.mjs"
    },
    "./meta": {
      "source": "./src/meta.ts",
      "types": "./dist/types/src/meta.d.ts",
      "browser": "./dist/lib/browser/meta.mjs",
      "node": "./dist/lib/node-esm/meta.mjs"
    },
    "./operations": {
      "source": "./src/operations/index.ts",
      "types": "./dist/types/src/operations/index.d.ts",
      "browser": "./dist/lib/browser/operations/index.mjs",
      "node": "./dist/lib/node-esm/operations/index.mjs"
    },
    "./translations": {
      "source": "./src/translations.ts",
      "types": "./dist/types/src/translations.d.ts",
      "browser": "./dist/lib/browser/translations.mjs",
      "node": "./dist/lib/node-esm/translations.mjs"
    }
  },
  "types": "dist/types/src/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@dxos/app-framework": "workspace:*",
    "@dxos/app-toolkit": "workspace:*",
    "@dxos/compute": "workspace:*",
    "@dxos/log": "workspace:*",
    "@dxos/util": "workspace:*",
    "effect": "catalog:"
  },
  "devDependencies": {
    "vite": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
