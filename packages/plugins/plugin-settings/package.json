{
  "name": "@dxos/plugin-settings",
  "version": "0.8.3",
  "private": true,
  "description": "DXOS Settings plugin for managing application settings.",
  "homepage": "https://dxos.org",
  "bugs": "https://github.com/dxos/dxos/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/dxos/dxos"
  },
  "license": "MIT",
  "author": "DXOS.org",
  "sideEffects": true,
  "type": "module",
  "imports": {
    "#capabilities": "./src/capabilities/index.ts",
    "#meta": "./src/meta.ts",
    "#operations": "./src/operations/index.ts",
    "#plugin": "./src/SettingsPlugin.ts",
    "#translations": "./src/translations.ts",
    "#types": "./src/types/index.ts"
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/types/src/index.d.ts",
      "import": "./dist/lib/index.mjs"
    },
    "./plugin": {
      "source": "./src/plugin.ts",
      "types": "./dist/types/src/plugin.d.ts",
      "import": "./dist/lib/plugin.mjs"
    },
    "./testing": {
      "source": "./src/testing.ts",
      "types": "./dist/types/src/testing.d.ts",
      "import": "./dist/lib/testing.mjs"
    },
    "./translations": {
      "source": "./src/translations.ts",
      "types": "./dist/types/src/translations.d.ts",
      "import": "./dist/lib/translations.mjs"
    }
  },
  "types": "dist/types/src/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@dxos/app-framework": "workspace:*",
    "@dxos/app-graph": "workspace:*",
    "@dxos/app-toolkit": "workspace:*",
    "@dxos/compute": "workspace:*",
    "@dxos/util": "workspace:*"
  },
  "devDependencies": {
    "@dxos/plugin-graph": "workspace:*",
    "@types/react": "catalog:",
    "effect": "catalog:",
    "react": "catalog:"
  },
  "peerDependencies": {
    "effect": "catalog:",
    "react": "catalog:"
  }
}
