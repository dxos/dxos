    "@dxos/async": "workspace:*",
    "@dxos/client-services": "workspace:*",
    "@dxos/compute": "workspace:*",
    "@dxos/compute-hyperformula": "workspace:*",
    "@dxos/conductor": "workspace:*",
    "@dxos/config": "workspace:*",
    "@dxos/devtools": "workspace:*",
    "@dxos/echo": "workspace:*",
    "@dxos/echo-pipeline": "workspace:*",
    "@dxos/effect": "workspace:*",
    "@dxos/invariant": "workspace:*",
    "@dxos/keys": "workspace:*",
    "@dxos/log": "workspace:*",
    "@dxos/log-store-idb": "workspace:*",
    "@dxos/operation": "workspace:*",
    "@dxos/plugin-client": "workspace:*",
    "@dxos/plugin-graph": "workspace:*",
    "@dxos/plugin-inbox": "workspace:*",
    "@dxos/plugin-markdown": "workspace:*",
    "@dxos/plugin-script": "workspace:*",
    "@dxos/plugin-sheet": "workspace:*",
    "@dxos/plugin-sketch": "workspace:*",
    "@dxos/plugin-space": "workspace:*",
    "@dxos/plugin-status-bar": "workspace:*",
    "@dxos/protocols": "workspace:*",
    "@dxos/random": "workspace:*",
    "@dxos/react-client": "workspace:*",
    "@dxos/react-ui-attention": "workspace:*",
    "@dxos/react-ui-canvas-compute": "workspace:*",
    "@dxos/react-ui-canvas-editor": "workspace:*",
    "@dxos/react-ui-form": "workspace:*",
    "@dxos/react-ui-introspect": "workspace:*",
    "@dxos/react-ui-syntax-highlighter": "workspace:*",
    "@dxos/schema": "workspace:*",
    "@dxos/tracing": "workspace:*",
    "@dxos/types": "workspace:*",
    "@dxos/util": "workspace:*",
    "@effect-atom/atom-react": "catalog:",
    "@tldraw/tldraw": "catalog:",
    "react-resize-detector": "catalog:"
  },
  "devDependencies": {
    "@dxos/plugin-testing": "workspace:*",
    "@dxos/react-ui": "workspace:*",
    "@dxos/storybook-utils": "workspace:*",
    "@dxos/ui-theme": "workspace:*",
    "@effect-atom/atom-react": "catalog:",
    "@effect/platform": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "effect": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "vite": "catalog:"
  },
  "peerDependencies": {
    "@dxos/random": "workspace:*",
    "@dxos/react-ui": "workspace:*",
    "@dxos/ui-theme": "workspace:*",
    "@effect-atom/atom-react": "catalog:",
    "@effect/platform": "catalog:",
    "effect": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
