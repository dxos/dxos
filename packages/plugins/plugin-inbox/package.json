      "node": "./dist/lib/InboxPlugin.node.mjs",
      "default": "./dist/lib/InboxPlugin.mjs"
    },
    "#testing": "./src/testing/index.ts",
    "#translations": {
      "source": "./src/translations.ts",
      "types": "./dist/types/src/translations.d.ts",
      "default": "./dist/lib/translations.mjs"
