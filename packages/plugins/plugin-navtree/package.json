      },
      "types": "./dist/types/src/NavTreePlugin.d.ts",
      "workerd": "./dist/lib/neutral/NavTreePlugin.workerd.mjs",
      "node": "./dist/lib/neutral/NavTreePlugin.node.mjs",
      "default": "./dist/lib/neutral/NavTreePlugin.mjs"
    },
