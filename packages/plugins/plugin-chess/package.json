{
  "name": "@dxos/plugin-chess",
  "version": "0.10.0",
  "description": "Chess for new plugin",
  "homepage": "https://dxos.org",
  "bugs": "https://github.com/dxos/dxos/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/dxos/dxos"
  },
  "license": "FSL-1.1-Apache-2.0",
  "author": "DXOS.org",
  "sideEffects": true,
  "type": "module",
  "imports": {
    "#skills": {
      "source": "./src/skills/index.ts",
      "types": "./dist/types/src/skills/index.d.ts",
      "default": "./dist/lib/skills.mjs"
    },
    "#capabilities": {
      "source": "./src/capabilities/index.ts",
      "types": "./dist/types/src/capabilities/index.d.ts",
      "default": "./dist/lib/capabilities.mjs"
    },
    "#components": {
      "source": "./src/components/index.ts",
      "types": "./dist/types/src/components/index.d.ts",
      "default": "./dist/lib/components.mjs"
    },
    "#containers": {
      "source": "./src/containers/index.ts",
      "types": "./dist/types/src/containers/index.d.ts",
      "default": "./dist/lib/containers.mjs"
    },
    "#meta": {
      "source": "./src/meta.ts",
      "types": "./dist/types/src/meta.d.ts",
      "default": "./dist/lib/meta.mjs"
    },
    "#operations": {
      "source": "./src/operations/index.ts",
      "types": "./dist/types/src/operations/index.d.ts",
      "default": "./dist/lib/operations.mjs"
    },
    "#plugin": {
      "source": {
        "workerd": "./src/ChessPlugin.workerd.ts",
        "node": "./src/ChessPlugin.node.ts",
        "default": "./src/ChessPlugin.tsx"
      },
      "types": "./dist/types/src/ChessPlugin.d.ts",
      "workerd": "./dist/lib/ChessPlugin.workerd.mjs",
      "node": "./dist/lib/ChessPlugin.node.mjs",
      "default": "./dist/lib/ChessPlugin.mjs"
    },
    "#translations": {
      "source": "./src/translations.ts",
      "types": "./dist/types/src/translations.d.ts",
      "default": "./dist/lib/translations.mjs"
    },
    "#types": {
      "source": "./src/types/index.ts",
      "types": "./dist/types/src/types/index.d.ts",
      "default": "./dist/lib/types.mjs"
    }
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/types/src/index.d.ts",
      "import": "./dist/lib/index.mjs"
    },
    "./assets/PLUGIN.mdl": "./PLUGIN.mdl",
    "./skills": {
      "source": "./src/skills/index.ts",
      "types": "./dist/types/src/skills/index.d.ts",
      "import": "./dist/lib/skills.mjs"
    },
    "./plugin": {
      "source": "./src/plugin.ts",
      "types": "./dist/types/src/plugin.d.ts",
      "import": "./dist/lib/plugin.mjs"
    },
    "./testing": {
      "source": "./src/testing.ts",
      "types": "./dist/types/src/testing.d.ts",
      "import": "./dist/lib/testing.mjs"
    },
    "./translations": {
      "source": "./src/translations.ts",
      "types": "./dist/types/src/translations.d.ts",
      "import": "./dist/lib/translations.mjs"
    },
    "./types": {
      "source": "./src/types/index.ts",
      "types": "./dist/types/src/types/index.d.ts",
      "import": "./dist/lib/types.mjs"
    }
  },
  "types": "dist/types/src/index.d.ts",
  "files": [
    "dist",
    "dx.config.ts",
    "src",
    "PLUGIN.mdl"
  ],
  "dependencies": {
    "@dxos/app-framework": "workspace:*",
    "@dxos/app-toolkit": "workspace:*",
    "@dxos/async": "workspace:*",
    "@dxos/compute": "workspace:*",
    "@dxos/echo": "workspace:*",
    "@dxos/echo-react": "workspace:*",
    "@dxos/invariant": "workspace:*",
    "@dxos/keys": "workspace:*",
    "@dxos/log": "workspace:*",
    "@dxos/plugin-client": "workspace:*",
    "@dxos/plugin-game": "workspace:*",
    "@dxos/react-client": "workspace:*",
    "@dxos/react-ui-audio": "workspace:*",
    "@dxos/react-ui-gameboard": "workspace:*",
    "@dxos/react-ui-mosaic": "workspace:*",
    "@dxos/util": "workspace:*",
    "@effect-atom/atom-react": "catalog:",
    "chess.js": "catalog:",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@dxos/agent-runtime": "workspace:*",
    "@dxos/effect": "workspace:*",
    "@dxos/plugin-testing": "workspace:*",
    "@dxos/plugin-theme": "workspace:*",
    "@dxos/react-ui": "workspace:*",
    "@dxos/storybook-utils": "workspace:*",
    "@dxos/ui-theme": "workspace:*",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "vite": "catalog:"
  },
  "peerDependencies": {
    "@dxos/react-ui": "workspace:^",
    "@dxos/ui-theme": "workspace:^",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
