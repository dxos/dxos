{
  "name": "@dxos/plugin-pipeline",
  "version": "0.8.3",
  "description": "Pipeline plugin for Composer",
  "homepage": "https://dxos.org",
  "bugs": "https://github.com/dxos/dxos/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/dxos/dxos"
  },
  "license": "FSL-1.1-Apache-2.0",
  "author": "DXOS.org",
  "sideEffects": true,
  "type": "module",
  "imports": {
    "#capabilities": {
      "source": "./src/capabilities/index.ts",
      "types": "./dist/types/src/capabilities/index.d.ts",
      "default": "./dist/lib/neutral/capabilities/index.mjs"
    },
    "#components": {
      "source": "./src/components/index.ts",
      "types": "./dist/types/src/components/index.d.ts",
      "default": "./dist/lib/neutral/components/index.mjs"
    },
    "#containers": {
      "source": "./src/containers/index.ts",
      "types": "./dist/types/src/containers/index.d.ts",
      "default": "./dist/lib/neutral/containers/index.mjs"
    },
    "#hooks": {
      "source": "./src/hooks/index.ts",
      "types": "./dist/types/src/hooks/index.d.ts",
      "default": "./dist/lib/neutral/hooks/index.mjs"
    },
    "#meta": {
      "source": "./src/meta.ts",
      "types": "./dist/types/src/meta.d.ts",
      "default": "./dist/lib/neutral/meta.mjs"
    },
    "#plugin": {
      "source": {
        "workerd": "./src/PipelinePlugin.workerd.ts",
        "node": "./src/PipelinePlugin.node.ts",
        "default": "./src/PipelinePlugin.tsx"
      },
      "types": "./dist/types/src/PipelinePlugin.d.ts",
      "workerd": "./dist/lib/neutral/PipelinePlugin.workerd.mjs",
      "node": "./dist/lib/neutral/PipelinePlugin.node.mjs",
      "default": "./dist/lib/neutral/PipelinePlugin.mjs"
    },
    "#translations": {
      "source": "./src/translations.ts",
      "types": "./dist/types/src/translations.d.ts",
      "default": "./dist/lib/neutral/translations.mjs"
    },
    "#types": {
      "source": "./src/types/index.ts",
      "types": "./dist/types/src/types/index.d.ts",
      "default": "./dist/lib/neutral/types/index.mjs"
    }
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/types/src/index.d.ts",
      "default": "./dist/lib/neutral/index.mjs"
    },
    "./assets/PLUGIN.mdl": "./PLUGIN.mdl",
    "./plugin": {
      "source": "./src/plugin.ts",
      "types": "./dist/types/src/plugin.d.ts",
      "default": "./dist/lib/neutral/plugin.mjs"
    },
    "./translations": {
      "source": "./src/translations.ts",
      "types": "./dist/types/src/translations.d.ts",
      "default": "./dist/lib/neutral/translations.mjs"
    }
  },
  "types": "dist/types/src/index.d.ts",
  "files": [
    "dist",
    "src",
    "PLUGIN.mdl"
  ],
  "dependencies": {
    "@dxos/app-framework": "workspace:*",
    "@dxos/app-toolkit": "workspace:*",
    "@dxos/compute": "workspace:*",
    "@dxos/devtools": "workspace:*",
    "@dxos/echo": "workspace:*",
    "@dxos/echo-query": "workspace:*",
    "@dxos/effect": "workspace:*",
    "@dxos/keys": "workspace:*",
    "@dxos/log": "workspace:*",
    "@dxos/plugin-client": "workspace:*",
    "@dxos/plugin-graph": "workspace:*",
    "@dxos/plugin-inbox": "workspace:*",
    "@dxos/plugin-markdown": "workspace:*",
    "@dxos/plugin-space": "workspace:*",
    "@dxos/react-client": "workspace:*",
    "@dxos/react-ui-attention": "workspace:*",
    "@dxos/react-ui-form": "workspace:*",
    "@dxos/react-ui-list": "workspace:*",
    "@dxos/react-ui-menu": "workspace:*",
    "@dxos/react-ui-mosaic": "workspace:*",
    "@dxos/react-ui-stack": "workspace:*",
    "@dxos/schema": "workspace:*",
    "@dxos/types": "workspace:*",
    "@dxos/util": "workspace:*",
    "@radix-ui/react-compose-refs": "catalog:",
    "@radix-ui/react-context": "catalog:",
    "@radix-ui/react-slot": "catalog:",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@dxos/echo-db": "workspace:*",
    "@dxos/plugin-attention": "workspace:*",
    "@dxos/plugin-inbox": "workspace:*",
    "@dxos/plugin-preview": "workspace:*",
    "@dxos/plugin-testing": "workspace:*",
    "@dxos/plugin-theme": "workspace:*",
    "@dxos/random": "workspace:*",
    "@dxos/react-ui": "workspace:*",
    "@dxos/storybook-utils": "workspace:*",
    "@dxos/ui-theme": "workspace:*",
    "@effect-atom/atom-react": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "vite": "catalog:"
  },
  "peerDependencies": {
    "@dxos/react-ui": "workspace:*",
    "@dxos/ui-theme": "workspace:*",
    "@effect-atom/atom-react": "catalog:",
    "effect": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
