{
  "name": "@dxos/plugin-client",
  "version": "0.8.3",
  "description": "DXOS Surface plugin for DXOS Client",
  "homepage": "https://dxos.org",
  "bugs": "https://github.com/dxos/dxos/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/dxos/dxos"
  },
  "license": "MIT",
  "author": "DXOS.org",
  "sideEffects": true,
  "type": "module",
  "imports": {
    "#capabilities": {
      "browser": "./src/capabilities/index.ts",
      "node": "./src/capabilities/node.ts",
      "default": "./src/capabilities/index.ts"
    },
    "#components": "./src/components/index.ts",
    "#containers": "./src/containers/index.ts",
    "#meta": "./src/meta.ts",
    "#operations": "./src/operations/index.ts",
    "#plugin": {
      "browser": "./src/ClientPlugin.ts",
      "node": "./src/ClientPlugin.node.ts",
      "default": "./src/ClientPlugin.ts"
    },
    "#testing": "./src/testing/index.ts",
    "#translations": "./src/translations.ts",
    "#types": "./src/types/index.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/types/src/index.d.ts",
      "import": "./dist/lib/index.mjs"
    },
    "./operations": {
      "types": "./dist/types/src/operations/index.d.ts",
      "import": "./dist/lib/operations.mjs"
    },
    "./plugin": {
      "types": "./dist/types/src/plugin.d.ts",
      "import": "./dist/lib/plugin.mjs"
    },
    "./testing": {
      "types": "./dist/types/src/testing/index.d.ts",
      "import": "./dist/lib/testing.mjs"
    },
    "./translations": {
      "types": "./dist/types/src/translations.d.ts",
      "import": "./dist/lib/translations.mjs"
    },
    "./types": {
      "types": "./dist/types/src/types/index.d.ts",
      "import": "./dist/lib/types.mjs"
    }
  },
  "types": "dist/types/src/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@dxos/app-framework": "workspace:*",
    "@dxos/app-toolkit": "workspace:*",
    "@dxos/async": "workspace:*",
    "@dxos/cli-util": "workspace:*",
    "@dxos/client": "workspace:*",
    "@dxos/client-protocol": "workspace:*",
    "@dxos/client-services": "workspace:*",
    "@dxos/compute": "workspace:*",
    "@dxos/config": "workspace:*",
    "@dxos/context": "workspace:*",
    "@dxos/echo": "workspace:*",
    "@dxos/effect": "workspace:*",
    "@dxos/invariant": "workspace:*",
    "@dxos/log": "workspace:*",
    "@dxos/plugin-graph": "workspace:*",
    "@dxos/plugin-observability": "workspace:*",
    "@dxos/protocols": "workspace:*",
    "@dxos/react-client": "workspace:*",
    "@dxos/react-ui-form": "workspace:*",
    "@dxos/react-ui-pickers": "workspace:*",
    "@dxos/react-ui-stack": "workspace:*",
    "@dxos/shell": "workspace:*",
    "@dxos/util": "workspace:*",
    "@effect/cli": "catalog:",
    "@effect/platform": "catalog:",
    "@tauri-apps/api": "catalog:",
    "effect": "catalog:",
    "react-qr-rounded": "catalog:",
    "yaml": "catalog:"
  },
  "devDependencies": {
    "@dxos/plugin-testing": "workspace:*",
    "@dxos/react-ui": "workspace:*",
    "@dxos/storybook-utils": "workspace:*",
    "@dxos/ui-theme": "workspace:*",
    "@effect-atom/atom-react": "catalog:",
    "@effect/printer": "catalog:",
    "@effect/printer-ansi": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "vite": "catalog:"
  },
  "peerDependencies": {
    "@dxos/react-ui": "workspace:*",
    "@dxos/ui-theme": "workspace:*",
    "@effect-atom/atom-react": "catalog:",
    "@effect/platform": "catalog:",
    "effect": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
