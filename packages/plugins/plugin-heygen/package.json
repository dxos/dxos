{
  "name": "@dxos/plugin-heygen",
  "version": "0.10.0",
  "private": true,
  "description": "HeyGen video-generation provider for Composer.",
  "homepage": "https://dxos.org",
  "bugs": "https://github.com/dxos/dxos/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/dxos/dxos"
  },
  "license": "FSL-1.1-Apache-2.0",
  "author": "DXOS.org",
  "sideEffects": true,
  "type": "module",
  "imports": {
    "#capabilities": {
      "source": "./src/capabilities/index.ts",
      "types": "./dist/types/src/capabilities/index.d.ts",
      "default": "./dist/lib/capabilities/index.mjs"
    },
    "#components": {
      "source": "./src/components/index.ts",
      "types": "./dist/types/src/components/index.d.ts",
      "default": "./dist/lib/components/index.mjs"
    },
    "#meta": {
      "source": "./src/meta.ts",
      "types": "./dist/types/src/meta.d.ts",
      "default": "./dist/lib/meta.mjs"
    },
    "#plugin": {
      "source": "./src/HeyGenPlugin.tsx",
      "types": "./dist/types/src/HeyGenPlugin.d.ts",
      "default": "./dist/lib/HeyGenPlugin.mjs"
    },
    "#services": {
      "source": "./src/services/index.ts",
      "types": "./dist/types/src/services/index.d.ts",
      "default": "./dist/lib/services/index.mjs"
    }
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/types/src/index.d.ts",
      "import": "./dist/lib/index.mjs"
    },
    "./plugin": {
      "source": "./src/plugin.ts",
      "types": "./dist/types/src/plugin.d.ts",
      "import": "./dist/lib/plugin.mjs"
    }
  },
  "types": "dist/types/src/index.d.ts",
  "files": [
    "dist",
    "dx.config.ts",
    "src",
    "PLUGIN.mdl"
  ],
  "dependencies": {
    "@dxos/app-framework": "workspace:*",
    "@dxos/app-toolkit": "workspace:*",
    "@dxos/echo": "workspace:*",
    "@dxos/edge-client": "workspace:*",
    "@dxos/invariant": "workspace:*",
    "@dxos/link": "workspace:*",
    "@dxos/log": "workspace:*",
    "@dxos/plugin-connector": "workspace:*",
    "@dxos/plugin-studio": "workspace:*",
    "@dxos/react-client": "workspace:*",
    "@dxos/react-ui-form": "workspace:*",
    "@dxos/util": "workspace:*",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@dxos/react-ui": "workspace:*",
    "@dxos/react-ui-list": "workspace:*",
    "@dxos/react-ui-syntax-highlighter": "workspace:*",
    "@types/react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
