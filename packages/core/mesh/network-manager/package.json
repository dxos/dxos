{
  "name": "@dxos/network-manager",
  "version": "0.11.0",
  "description": "Network Manager",
  "homepage": "https://dxos.org",
  "bugs": "https://github.com/dxos/dxos/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/dxos/dxos"
  },
  "license": "FSL-1.1-Apache-2.0",
  "author": "DXOS.org",
  "sideEffects": false,
  "type": "module",
  "imports": {
    "#node-datachannel": {
      "browser": "./module-stub.mjs",
      "workerd": "./module-stub.mjs",
      "default": "node-datachannel"
    },
    "#node-datachannel/*": {
      "browser": "./module-stub.mjs",
      "workerd": "./module-stub.mjs",
      "default": "node-datachannel/*"
    },
    "#tcp-transport": {
      "source": "./src/transport/tcp/index.ts",
      "types": "./dist/types/src/transport/tcp/index.d.ts",
      "browser": "./dist/lib/transport/tcp.mjs",
      "node": "./dist/lib/transport/tcp.mjs",
      "import": "./dist/lib/transport/tcp.mjs",
      "require": "./dist/lib/transport/tcp.mjs"
    },
    "#tcp-transport-impl": {
      "source": {
        "browser": "./src/transport/tcp/tcp-transport.browser.ts",
        "default": "./src/transport/tcp/tcp-transport.ts"
      },
      "types": "./dist/types/src/transport/tcp/tcp-transport.d.ts",
      "browser": "./dist/lib/transport/tcp/tcp-transport.browser.mjs",
      "default": "./dist/lib/transport/tcp/tcp-transport.mjs"
    }
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/types/src/index.d.ts",
      "import": "./dist/lib/index.mjs"
    },
    "./testing": {
      "source": "./src/testing/index.ts",
      "types": "./dist/types/src/testing/index.d.ts",
      "import": "./dist/lib/testing.mjs"
    },
    "./transport/tcp": {
      "source": "./src/transport/tcp/index.ts",
      "types": "./dist/types/src/transport/tcp/index.d.ts",
      "import": "./dist/lib/transport/tcp.mjs"
    }
  },
  "types": "dist/types/src/index.d.ts",
  "files": [
    "testing.d.ts",
    "testing.js",
    "module-stub.mjs",
    "dist",
    "src"
  ],
  "dependencies": {
    "@dxos/async": "workspace:*",
    "@dxos/codec-protobuf": "workspace:*",
    "@dxos/context": "workspace:*",
    "@dxos/debug": "workspace:*",
    "@dxos/invariant": "workspace:*",
    "@dxos/keys": "workspace:*",
    "@dxos/log": "workspace:*",
    "@dxos/messaging": "workspace:*",
    "@dxos/node-std": "workspace:*",
    "@dxos/protocols": "workspace:*",
    "@dxos/rpc": "workspace:*",
    "@dxos/teleport": "workspace:*",
    "@dxos/tracing": "workspace:*",
    "@dxos/util": "workspace:*",
    "effect": "catalog:",
    "node-datachannel": "catalog:"
  },
  "devDependencies": {
    "@dxos/edge-client": "workspace:*",
    "@dxos/keyring": "workspace:*",
    "fetch-mock": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  },
  "beast": {
    "classDiagrams": [
      {
        "root": "src/network-manager.ts"
      }
    ]
  }
}
