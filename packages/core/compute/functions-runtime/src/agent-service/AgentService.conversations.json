        "tools": [
          {
            "name": "set-alarm",
            "description": "Schedule an alarm to wake yourself up in the future.\nProvide exactly one of \"in\" (a duration from now) or \"at\" (an absolute time).\nWhen the alarm fires you will receive a prompt and can continue working.\nSetting a new alarm replaces any previously scheduled one.",
            "inputSchema": {
              "type": "object",
              "required": [],
              "properties": {
                "in": {
                  "type": "string",
                  "description": "Duration from now expressed as \"<number> <unit>\", e.g. \"30 seconds\", \"5 minutes\", \"2 hours\"."
                },
                "at": {
                  "type": "string",
                  "description": "Absolute ISO-8601 timestamp to wake at, e.g. \"2026-06-04T18:00:00.000Z\"."
                }
              },
              "additionalProperties": false
            }
          },
          {
            "name": "get-current-date",
            "description": "Get the current date and time as an ISO-8601 string.",
            "inputSchema": {
              "type": "object",
              "required": [],
              "properties": {
                "timezone": {
                  "type": "string",
                  "description": "Optional IANA timezone name. Defaults to the process clock when omitted."
                }
              },
              "additionalProperties": false
            }
          }
        ]
      },
      "prompt": {
        "content": [
          {
            "role": "system",
            "content": "You are a helpful assistant with access to alarm tools (set-alarm, get-current-date).\nWhen asked to set an alarm, you MUST call the set-alarm tool with the requested duration.\nDo not pretend to set an alarm in text — always use the set-alarm tool.\nAfter the tool succeeds, briefly confirm the alarm was scheduled and stop.\nWhen you receive a wake-up notification that your alarm fired, acknowledge it briefly in text.",
            "options": {}
          },
          {
            "role": "user",
            "content": "Use the set-alarm tool to schedule a wake-up in 1 hour.",
            "options": {
              "anthropic": {
                "cacheControl": {
                  "ttl": "5m",
                  "type": "ephemeral"
                }
              }
            }
          }
        ]
      },
