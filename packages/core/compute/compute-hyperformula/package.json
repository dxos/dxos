{
  "name": "@dxos/compute-hyperformula",
  "version": "0.9.0",
  "private": true,
  "description": "HyperFormula-based compute graph (spreadsheet) engine.",
  "homepage": "https://dxos.org",
  "bugs": "https://github.com/dxos/dxos/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/dxos/dxos"
  },
  "license": "FSL-1.1-Apache-2.0",
  "author": "DXOS.org",
  "sideEffects": true,
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/types/src/index.d.ts",
      "default": "./dist/lib/neutral/index.mjs"
    },
    "./testing": {
      "source": "./src/testing/index.ts",
      "types": "./dist/types/src/testing/index.d.ts",
      "default": "./dist/lib/neutral/testing/index.mjs"
    }
  },
  "types": "dist/types/src/index.d.ts",
  "typesVersions": {
    "*": {
      "testing": [
        "dist/types/src/testing/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@dxos/async": "workspace:*",
    "@dxos/client": "workspace:*",
    "@dxos/compute": "workspace:*",
    "@dxos/context": "workspace:*",
    "@dxos/debug": "workspace:*",
    "@dxos/echo": "workspace:*",
    "@dxos/invariant": "workspace:*",
    "@dxos/keys": "workspace:*",
    "@dxos/log": "workspace:*",
    "@dxos/util": "workspace:*",
    "@dxos/vendor-hyperformula": "workspace:*",
    "effect": "catalog:",
    "lodash.defaultsdeep": "catalog:"
  },
  "devDependencies": {
    "@dxos/echo": "workspace:*",
    "@dxos/random": "workspace:*",
    "@tldraw/indices": "catalog:",
    "@types/lodash.defaultsdeep": "catalog:"
  },
  "peerDependencies": {
    "effect": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
