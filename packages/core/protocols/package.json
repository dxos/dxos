{
  "name": "@dxos/protocols",
  "version": "0.10.0",
  "description": "Protobuf definitions for DXOS protocols.",
  "homepage": "https://dxos.org",
  "bugs": "https://github.com/dxos/dxos/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/dxos/dxos"
  },
  "license": "FSL-1.1-Apache-2.0",
  "author": "info@dxos.org",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "browser": "./dist/src/index.js",
      "import": "./dist/src/index.js"
    },
    "./feed-replication": {
      "browser": "./dist/src/feed-replication.js",
      "import": "./dist/src/feed-replication.js"
    },
    "./rpc": {
      "browser": "./dist/src/rpc.js",
      "import": "./dist/src/rpc.js"
    },
    "./proto": {
      "browser": "./dist/src/proto/index.js",
      "import": "./dist/src/proto/index.js"
    },
    "./proto/dxos/*.proto": "./src/proto/dxos/*.proto",
    "./proto/*": {
      "browser": "./dist/src/proto/gen/*.js",
      "import": "./dist/src/proto/gen/*.js"
    },
    "./buf": {
      "browser": "./dist/src/buf/index.js",
      "import": "./dist/src/buf/index.js"
    },
    "./buf/*": {
      "browser": "./dist/src/buf/proto/gen/*.js",
      "import": "./dist/src/buf/proto/gen/*.js"
    },
    "./lexicons/*": "./src/lexicons/*"
  },
  "types": "dist/src/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@bufbuild/protobuf": "catalog:",
    "@dxos/codec-protobuf": "workspace:*",
    "@dxos/effect": "workspace:*",
    "@dxos/errors": "workspace:*",
    "@dxos/invariant": "workspace:*",
    "@dxos/keys": "workspace:*",
    "@dxos/timeframe": "workspace:*",
    "@effect/rpc": "catalog:"
  },
  "devDependencies": {
    "@bufbuild/buf": "catalog:",
    "@bufbuild/protoc-gen-es": "catalog:",
    "@dxos/protobuf-compiler": "workspace:*",
    "effect": "catalog:"
  },
  "peerDependencies": {
    "effect": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
