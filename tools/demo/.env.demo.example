# Copy this file to .env.demo (in the same directory) and fill in real values.
# .env.demo is gitignored — your real credentials stay out of the repo.
#
# Used by tools/demo/setup.ts to bootstrap a Composer session with real
# Trello / Granola / Slack / GitHub connectivity for recording.

# -- LLM -----------------------------------------------------------------------

# Anthropic API key (required for aiMatch, Slack bot answers, and blueprints).
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# -- Demo persona --------------------------------------------------------------

# The name shown in the workspace as the "you" for the demo.
DEMO_PERSONA_NAME=Sarah Chen
DEMO_PERSONA_EMAIL=sarah@acme.example
DEMO_ORG_NAME=ACME Corp

# Slack user ID to @-mention in proactive nudges. Looks like "U021CNBHADA".
# Use Slack user IDs, not names — plain "@chad" won't create a notification.
# Get yours: open your Slack profile → More (⋮) → "Copy member ID".
DEMO_NUDGE_MENTION_ID=
# Display name rendered in the previewed nudge text (if the mention ID is
# missing or we're rendering in the panel-only preview view).
DEMO_NUDGE_MENTION_NAME=you

# Optional: override the PR author attribution in the nudge. Handy when the
# GitHub PR was opened by the same person running the demo, but the narrative
# needs a different "someone on your team shipped this" actor. If
# DEMO_PR_AUTHOR_ID is set, it's rendered as a real Slack <@ID> ping; else
# falls back to DEMO_PR_AUTHOR_NAME (plain text, no ping); else falls back
# to the real GitHub login.
DEMO_PR_AUTHOR_ID=
DEMO_PR_AUTHOR_NAME=

# Fresh-start behavior: if true, the setup script wipes the current Composer
# identity and creates a new one before seeding. Safe for recording; do NOT
# run with this = true against a Composer you care about.
DEMO_FRESH_START=false

# -- Trello --------------------------------------------------------------------

# Trello API key + token.
# Key: https://trello.com/power-ups/admin
# Token: https://trello.com/1/authorize?key=YOUR_KEY&scope=read,write&name=ComposerDemo&response_type=token
TRELLO_API_KEY=
TRELLO_API_TOKEN=
# The board ID to sync (the string after /b/ in the board URL).
TRELLO_BOARD_ID=

# -- Granola -------------------------------------------------------------------

# Granola API key (Granola app → Settings → API).
GRANOLA_API_KEY=

# -- Slack ---------------------------------------------------------------------

# Slack bot token (xoxb-…) from your Slack app's "OAuth & Permissions" page.
# Scopes needed: channels:history, channels:read, chat:write, users:read.
SLACK_BOT_TOKEN=
# Channels (comma-separated) the bot should monitor + post into.
SLACK_CHANNELS=widgets-eng,widgets-product
# The channel used for proactive nudges in the demo.
SLACK_NUDGE_CHANNEL=widgets-eng

# -- GitHub --------------------------------------------------------------------

# GitHub personal access token with `public_repo` scope (or fine-grained with
# read access to the demo repo). https://github.com/settings/tokens
GITHUB_PAT=
# Repo to monitor for PR merges during the demo (owner/name).
GITHUB_REPO=acme/widgets

# -- Run-demo orchestrator -----------------------------------------------------

# When true, the demo panel will actually post proactive nudges to real Slack
# (chat.postMessage) using SLACK_BOT_TOKEN + SLACK_NUDGE_CHANNEL. Leave false
# for dry-run rehearsals.
DEMO_LIVE_SLACK=false
# Optional: if set, run.ts will also open Slack web in a second tab so the
# posted message is visible in the screen recording.
DEMO_OPEN_SLACK_WEB=true

# Cross-surface chat: mirror Slack DMs into Composer Chat objects
DEMO_CROSS_SURFACE_CHAT=false
# DEMO_CHAT_CHANNELS=  # Optional: comma-separated channel IDs/names. Falls back to SLACK_NUDGE_CHANNEL.
