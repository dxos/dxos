{
  "name": "@dxos/vite-plugin-log",
  "version": "0.11.0",
  "private": true,
  "description": "Vite dev server plugin: stream @dxos/log NDJSON to a local file via HMR channel; Vitest file sink for Node tests.",
  "homepage": "https://dxos.org",
  "bugs": "https://github.com/dxos/dxos/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/dxos/dxos"
  },
  "license": "FSL-1.1-Apache-2.0",
  "author": "DXOS.org",
  "sideEffects": [
    "src/runtime.ts",
    "dist/src/runtime.js"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./runtime": {
      "types": "./dist/src/runtime.d.ts",
      "default": "./dist/src/runtime.js"
    },
    "./vitest": {
      "source": "./src/vitest/index.ts",
      "types": "./dist/src/vitest/index.d.ts",
      "default": "./dist/src/vitest/index.js"
    },
    "./vitest/global-setup": {
      "source": "./src/vitest/global-setup.ts",
      "types": "./dist/src/vitest/global-setup.d.ts",
      "default": "./dist/src/vitest/global-setup.js"
    },
    "./vitest/setup": {
      "source": "./src/vitest/setup.ts",
      "types": "./dist/src/vitest/setup.d.ts",
      "default": "./dist/src/vitest/setup.js"
    }
  },
  "types": "dist/src/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "test": "vitest run --passWithNoTests --project=node"
  },
  "devDependencies": {
    "@dxos/log": "workspace:*",
    "@dxos/util": "workspace:*",
    "@oxc-project/types": "catalog:",
    "rolldown": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@dxos/log": "workspace:^",
    "@dxos/util": "workspace:^",
    "rolldown": ">=1.0.0-beta.0",
    "vite": "catalog:"
  },
  "peerDependenciesMeta": {
    "rolldown": {
      "optional": true
    }
  }
}
